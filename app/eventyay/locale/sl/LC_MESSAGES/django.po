msgstr "Te naprave ne bo več mogoče uporabljati za prijavo v pretix."

#: eventyay_common/templates/eventyay_common/account/2fa-delete.html:27
msgid ""
"If this is the only device connected to your account, we will disable two-"
"factor authentication."
msgstr ""
"Če je to edina naprava, povezana z računom, bo dvostopenjsko preverjanje "
"pristnosti onemogočeno."

