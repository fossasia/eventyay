#: base/settings.py:186
msgid "The last payment date cannot be before the end of presale."
msgstr "Datum zadnjega plačila ne sme biti pred koncem predprodaje."

#: base/shredder.py:47 base/shredder.py:50
msgid "Your event needs to be over for at least 30 days to use this feature."
msgstr "Dogodek mora biti zaključen vsaj 30 dni za uporabo te funkcije."

#: base/shredder.py:52
msgid "Your ticket shop needs to be offline to use this feature."
msgstr "Prodaja vstopnic mora biti brez povezave za uporabo te funkcije."

#: base/shredder.py:142
msgid "Phone numbers"
msgstr "Telefonske številke"

#: base/shredder.py:144
msgid "This will remove all phone numbers from orders."
msgstr "To bo odstranilo vse telefonske številke iz naročil."

#: base/shredder.py:173
msgid "E-mails"
msgstr "E-poštni naslovi"

#: base/shredder.py:176
msgid ""
"This will remove all e-mail addresses from orders and attendees, as well as "
"logged email contents."
msgstr ""
"To bo odstranilo vse e-poštne naslove iz naročil in udeležencev ter "
"zabeleženo vsebino e-pošte."

#: base/shredder.py:233
msgid ""
"This will remove all names, email addresses, and phone numbers from the "
"waiting list."
msgstr ""
"To bo odstranilo vsa imena, e-poštne naslove in telefonske številke s "
"čakalnega seznama."

#: base/shredder.py:268
msgid "Attendee info"
msgstr "Podatki o udeležencu"

#: base/shredder.py:271
msgid ""
"This will remove all attendee names and postal addresses from order "
"positions, as well as logged changes to them."
msgstr ""
"To bo odstranilo vsa imena udeležencev in poštne naslove iz postavk naročila "
"ter zabeležene spremembe."

#: base/shredder.py:338
msgid "Invoice addresses"
msgstr "Naslovi za račune"

#: base/shredder.py:341
msgid ""
"This will remove all invoice addresses from orders, as well as logged "
"changes to them."
msgstr ""
"To bo odstranilo vse naslove za račune iz naročil ter zabeležene spremembe."

#: base/shredder.py:372
msgid "Question answers"
msgstr "Odgovori na vprašanja"

#: base/shredder.py:374
msgid ""
"This will remove all answers to questions, as well as logged changes to them."
msgstr "To bo odstranilo vse odgovore na vprašanja ter zabeležene spremembe."

#: base/shredder.py:411
msgid ""
"This will remove all invoice PDFs, as well as any of their text content that "
"might contain personal data from the database. Invoice numbers and totals "
"will be conserved."
msgstr ""
"To bo odstranilo vse PDF-je računov in morebitno besedilno vsebino, ki lahko "
"vsebuje osebne podatke, iz podatkovne baze. Številke računov in zneski bodo "
"ohranjeni."

#: base/shredder.py:439
msgid "Cached ticket files"
msgstr "Predpomnjene datoteke vstopnic"

#: base/shredder.py:441
msgid "This will remove all cached ticket files. No download will be offered."
msgstr ""
"To bo odstranilo vse predpomnjene datoteke vstopnic. Prenos ne bo na voljo."

#: base/shredder.py:457
msgid ""
"This will remove payment-related information. Depending on the payment "
"method, all data will be removed or personal data only. No download will be "
"offered."
msgstr ""
"To bo odstranilo podatke, povezane s plačili. Glede na način plačila bodo "
"odstranjeni vsi podatki ali samo osebni podatki. Prenos ne bo na voljo."

