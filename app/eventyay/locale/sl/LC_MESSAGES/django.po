#: control/forms/organizer_forms/organizer_form.py:106
#: plugins/checkinlists/exporters.py:540 plugins/reports/exporters.py:863
msgid "City"
msgstr "Mesto"

#: base/configurations/default_setting.py:781 base/exporters/invoices.py:191
#: base/exporters/invoices.py:199 base/exporters/invoices.py:331
#: base/exporters/invoices.py:339 base/exporters/orderlist.py:399
