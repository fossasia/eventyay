#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"This is an access code for the {event} CfP."
msgstr ""
"હાય!\n"
"\n"
"આ {event} CfP માટેનો ઍક્સેસ કોડ છે."

#: orga/forms/cfp.py:564
#, python-brace-format
msgid "It will allow you to submit a proposal to the “{track}” track."
msgstr "તે “{track}” ટ્રેક માટે પ્રસ્તાવ સબમિટ કરવાની મંજૂરી આપશે."

#: orga/forms/cfp.py:571
msgid "It will allow you to submit a proposal to our CfP."
msgstr "તે અમારી CfP માટે પ્રસ્તાવ સબમિટ કરવાની મંજૂરી આપશે."

#: orga/forms/cfp.py:575
#, python-brace-format
msgid "This access code is valid until {date}."
msgstr "આ ઍક્સેસ કોડ {date} સુધી માન્ય છે."

#: orga/forms/cfp.py:582
#, python-brace-format
