#: base/payment.py:263
msgid ""
"Users will not be able to choose this payment provider after the given date."
msgstr "આપેલ તારીખ પછી વપરાશકર્તાઓ આ ચુકવણી પ્રદાતા પસંદ કરી શકશે નહીં."

#: base/payment.py:270
msgid "Text on invoices"
msgstr "ઇન્વૉઇસ પરનો લખાણ"

#: base/payment.py:272
msgid ""
"Will be printed just below the payment figures and above the closing text on "
"invoices. This will only be used if the invoice is generated before the "
"order is paid. If the invoice is generated later, it will show a text "
"stating that it has already been paid."
msgstr ""
"ઇન્વૉઇસમાં ચુકવણી આંકડાઓની બરાબર નીચે અને સમાપન લખાણની ઉપર છપાશે. આ લખાણ માત્ર ત્યારે "
"જ વપરાશે જ્યારે ઓર્ડર ચૂકવાયો હોય તે પહેલાં ઇન્વૉઇસ જનરેટ થાય. જો ઇન્વૉઇસ પછીથી જનરેટ "
"થાય, તો તેમાં પહેલેથી ચૂકવાયેલું હોવાનું દર્શાવતું લખાણ દેખાશે."

#: base/payment.py:284
msgid "Minimum order total"
msgstr "ઓર્ડરનું ન્યૂનતમ કુલ"

#: base/payment.py:286
msgid ""
"This payment will be available only if the order total is equal to or "
"exceeds the given value. The order total for this purpose may be computed "
"without taking the fees imposed by this payment method into account."
msgstr ""
"આ ચુકવણી ફક્ત ત્યારે જ ઉપલબ્ધ રહેશે જ્યારે ઓર્ડરનું કુલ આપેલા મૂલ્ય જેટલું અથવા તેથી વધુ હશે. આ હેતુ "
"માટે ઓર્ડરનું કુલ આ ચુકવણી પદ્ધતિ દ્વારા લાદવામાં આવેલી ફી ધ્યાનમાં લીધા વિના ગણવામાં આવી "
"શકે છે."

#: base/payment.py:299
msgid "Maximum order total"
msgstr "ઓર્ડરનું મહત્તમ કુલ"

#: base/payment.py:301
msgid ""
"This payment will be available only if the order total is equal to or below "
"the given value. The order total for this purpose may be computed without "
"taking the fees imposed by this payment method into account."
msgstr ""
"આ ચુકવણી ફક્ત ત્યારે જ ઉપલબ્ધ રહેશે જ્યારે ઓર્ડરનું કુલ આપેલા મૂલ્ય જેટલું અથવા તેનાથી ઓછું હશે. આ "
"હેતુ માટે ઓર્ડરનું કુલ આ ચુકવણી પદ્ધતિ દ્વારા લાદવામાં આવેલી ફી ધ્યાનમાં લીધા વિના ગણવામાં "
"આવી શકે છે."

#: base/payment.py:314 base/payment.py:325
msgid "Additional fee"
msgstr "વધારાની ફી"

#: base/payment.py:315
msgid "Absolute value"
msgstr "નિરપેક્ષ મૂલ્ય"

#: base/payment.py:326
msgid "Percentage of the order total."
msgstr "ઓર્ડર કુલની ટકાવારી."

#: base/payment.py:334
msgid "Calculate the fee from the total value including the fee."
msgstr "ફી સહિતના કુલ મૂલ્ય પરથી ફી ગણો."

#: base/payment.py:336
#, python-brace-format
msgid ""
"We recommend to enable this if you want your users to pay the payment fees "
"of your payment provider. <a href=\"{docs_url}\" target=\"_blank\" "
"rel=\"noopener\">Click here for detailed information on what this does.</a> "
"Don't forget to set the correct fees above!"
msgstr ""
"જો વપરાશકર્તાઓએ તમારી ચુકવણી પ્રદાતાની ચુકવણી ફી ચૂકવવી હોય, તો આ સક્રિય કરવાની "
"ભલામણ કરવામાં આવે છે. <a href=\"{docs_url}\" target=\"_blank\" "
"rel=\"noopener\">આ શું કરે છે તેની વિગતવાર માહિતી માટે અહીં ક્લિક કરો.</a> ઉપર યોગ્ય "
"ફી સેટ કરવાનું ભૂલશો નહીં!"

#: base/payment.py:347
msgid "Restrict to countries"
msgstr "દેશો સુધી મર્યાદિત કરો"

#: base/payment.py:350
msgid ""
"Only allow choosing this payment provider for invoice addresses in the "
"selected countries. If you don't select any country, all countries are "
"allowed. This is only enabled if the invoice address is required."
msgstr ""
"પસંદ કરેલા દેશોમાં ઇન્વોઇસ સરનામા માટે જ આ ચુકવણી પ્રદાતા પસંદ કરવાની મંજૂરી આપો. જો "
"કોઈ દેશ પસંદ ન કરાયો હોય, તો બધા દેશો મંજૂર છે. ઇન્વોઇસ સરનામું આવશ્યક હોય ત્યારે જ આ "
"સક્રિય રહેશે."

#: base/payment.py:370
msgid ""
"Only allow the usage of this payment provider in the selected sales channels."
msgstr "પસંદ કરેલા વેચાણ ચેનલોમાં જ આ ચુકવણી પ્રદાતાનો ઉપયોગ કરવાની મંજૂરી આપો."

#: base/payment.py:376
msgid "Hide payment method"
msgstr "ચુકવણી પદ્ધતિ છુપાવો"

#: base/payment.py:379
msgid ""
"The payment method will not be shown by default but only to people who enter "
"the shop through a special link."
msgstr ""
"ચુકવણી પદ્ધતિ મૂળભૂત રીતે બતાવવામાં આવશે નહીં, પરંતુ ફક્ત તેમને જ બતાવવામાં આવશે જેઓ ખાસ લિંક "
"દ્વારા દુકાનમાં પ્રવેશે છે."

#: base/payment.py:387
msgid "Link to enable payment method"
msgstr "ચુકવણી પદ્ધતિ સક્રિય કરવાની લિંક"

#: base/payment.py:397
msgid "Share this link with customers who should use this payment method."
msgstr "જેઓ આ ચુકવણી પદ્ધતિનો ઉપયોગ કરવા જોઈએ તે ગ્રાહકો સાથે આ લિંક શેર કરો."

#: base/payment.py:431
msgctxt "invoice"
msgid "The payment for this invoice has already been received."
msgstr "આ ઇન્વોઇસ માટેની ચુકવણી પહેલેથી પ્રાપ્ત થઈ ગઈ છે."

#: base/payment.py:843
