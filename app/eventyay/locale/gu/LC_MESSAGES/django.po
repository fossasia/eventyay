msgstr "આ ગિફ્ટ કાર્ડ ફક્ત ટેસ્ટ મોડમાં જ વાપરી શકાય છે."

#: base/payment.py:1271 base/payment.py:1357 base/services/orders.py:981
msgid "Only test gift cards can be used in test mode."
msgstr "ટેસ્ટ મોડમાં ફક્ત ટેસ્ટ ગિફ્ટ કાર્ડ જ વાપરી શકાય છે."

#: base/payment.py:1274 base/payment.py:1360 base/payment.py:1409
msgid "This gift card is no longer valid."
msgstr "આ ગિફ્ટ કાર્ડ હવે માન્ય નથી."

#: base/payment.py:1277 base/payment.py:1363
msgid "All credit on this gift card has been used."
msgstr "આ ગિફ્ટ કાર્ડ પરનું બધું ક્રેડિટ વપરાઈ ગયું છે."

#: base/payment.py:1282
msgid "This gift card is already used for your payment."
msgstr "આ ગિફ્ટ કાર્ડ પહેલેથી ચુકવણી માટે ઉપયોગમાં લેવાઈ ચૂક્યું છે."

#: base/payment.py:1304
#, python-brace-format
msgid ""
"Your gift card has been applied, but {} still need to be paid. Please select "
"a payment method."
msgstr ""
"ગિફ્ટ કાર્ડ લાગુ કરવામાં આવ્યું છે, પરંતુ હજી પણ {} ચુકવવાનું બાકી છે. ચુકવણી પદ્ધતિ પસંદ કરો."

#: base/payment.py:1308
msgid "Your gift card has been applied."
msgstr "ગિફ્ટ કાર્ડ લાગુ કરવામાં આવ્યું છે."

#: base/payment.py:1319 base/payment.py:1375
msgid ""
"You entered a voucher instead of a gift card. Vouchers can only be entered "
"on the first page of the shop below the product selection."
msgstr ""
"ગિફ્ટ કાર્ડના બદલે વાઉચર દાખલ કરવામાં આવ્યું છે. વાઉચર માત્ર દુકાનના પ્રથમ પૃષ્ઠ પર, "
"પ્રોડક્ટ પસંદગીની નીચે દાખલ કરી શકાય છે."

#: base/payment.py:1324 base/payment.py:1380
msgid "This gift card is not known."
msgstr "આ ગિફ્ટ કાર્ડ ઓળખાતું નથી."

#: base/payment.py:1329 base/payment.py:1385
msgid ""
"This gift card can not be redeemed since its code is not unique. Please "
"contact the organizer of this event."
