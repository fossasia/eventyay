#: base/payment.py:1027
msgid "Payment process description during checkout"
msgstr "ચેકઆઉટ દરમિયાન ચુકવણી પ્રક્રિયાનું વર્ણન"

#: base/payment.py:1029
msgid ""
"This text will be shown during checkout when the user selects this payment "
"method. It should give a short explanation on this payment method."
msgstr ""
"વપરાશકર્તા આ ચુકવણી પદ્ધતિ પસંદ કરે ત્યારે ચેકઆઉટ દરમિયાન આ લખાણ બતાવવામાં આવશે. તેમાં આ "
"ચુકવણી પદ્ધતિ વિશેનું ટૂંકું સ્પષ્ટીકરણ હોવું જોઈએ."

#: base/payment.py:1038
msgid "Payment process description in order confirmation emails"
msgstr "ઓર્ડર પુષ્ટિ ઇમેલમાં ચુકવણી પ્રક્રિયાનું વર્ણન"

#: base/payment.py:1040
#, python-brace-format
msgid ""
"This text will be included for the {payment_info} placeholder in order "
"confirmation mails. It should instruct the user on how to proceed with the "
"payment. You can use the placeholders {order}, {amount}, {currency} and "
"{amount_with_currency}."
msgstr ""
"ઓર્ડર પુષ્ટિ ઇમેલમાં {payment_info} પ્લેસહોલ્ડર માટે આ લખાણ ઉમેરવામાં આવશે. તેમાં "
"વપરાશકર્તાને ચુકવણી માટે આગળ કેવી રીતે વધવું તે અંગે સૂચના આપવી જોઈએ. {order}, {amount}, "
"{currency} અને {amount_with_currency} પ્લેસહોલ્ડરનો ઉપયોગ કરી શકાય છે."

#: base/payment.py:1060
msgid "Payment process description for pending orders"
msgstr "બાકી રહેલા ઓર્ડર માટે ચુકવણી પ્રક્રિયાનું વર્ણન"

#: base/payment.py:1062
#, python-brace-format
msgid ""
"This text will be shown on the order confirmation page for pending orders. "
"It should instruct the user on how to proceed with the payment. You can use "
"the placeholders {order}, {amount}, {currency} and {amount_with_currency}."
msgstr ""
"બાકી રહેલા ઓર્ડર માટે ઓર્ડર પુષ્ટિ પેજ પર આ લખાણ બતાવવામાં આવશે. તેમાં વપરાશકર્તાને ચુકવણી "
"માટે આગળ કેવી રીતે વધવું તે અંગે સૂચના આપવી જોઈએ. {order}, {amount}, {currency} અને "
"{amount_with_currency} પ્લેસહોલ્ડરનો ઉપયોગ કરી શકાય છે."

#: base/payment.py:1125
msgid "Offsetting"
