msgstr "Includi il numero della fattura nel riferimento di pagamento."

#: plugins/banktransfer/payment.py:166
msgid "Prefix for the payment reference"
msgstr "Prefisso per il riferimento di pagamento"

#: plugins/banktransfer/payment.py:173
