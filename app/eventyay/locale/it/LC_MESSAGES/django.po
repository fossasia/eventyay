#: control/templates/pretixcontrol/subevents/detail.html:219
msgid "Additional settings"
msgstr "Impostazioni aggiuntive"

#: control/templates/pretixcontrol/item/index.html:139
msgid "Product history"
msgstr "Cronologia del prodotto"

#: control/templates/pretixcontrol/items/categories.html:14
msgid ""
"You can use categories to group multiple products together in an organized "
