#, python-format
msgid ""
"You cannot delete the product <strong>%(item)s</strong> because it already "
"has been ordered."
msgstr ""
"Produkt <strong>%(item)s</strong> nemůžete smazat, protože už byl objednán."

#: control/templates/pretixcontrol/item/delete.html:19
#, python-format
