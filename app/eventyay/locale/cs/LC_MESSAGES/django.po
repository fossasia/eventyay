msgstr ""
"Objednávka byla změněna. Nyní můžete pokračovat zaplacením neuhrazené částky "
"{amount}."

#: presale/views/user.py:27
msgid "We had difficulties processing your input."
msgstr "Při zpracování vašeho zadání jsme narazili na potíže."

#: presale/views/user.py:40
#, python-brace-format
msgid ""
"If the email address you entered is valid and associated with a ticket, we "
"have already sent you an email with a link to your ticket in the past "
"{number} hours. If the email did not arrive, please your check spam folder "
"and also double check that you used the correct email address."
msgstr ""
"Pokud je zadaná e-mailová adresa platná a je přiřazena ke vstupence, už jsme "
"vám v uplynulých {number} hodinách poslali e-mail s odkazem na vaši "
"vstupenku. Pokud e-mail nedorazil, zkontrolujte prosím složku se spamem a "
"také si ověřte, že jste použili správnou e-mailovou adresu."

#: presale/views/user.py:55
#, python-brace-format
msgid "Your orders for {}"
msgstr "Vaše objednávky pro {}"

#: presale/views/user.py:72
msgid "We have trouble sending emails right now, please check back later."
msgstr "Momentálně máme potíže s odesíláním e-mailů, zkuste to prosím později."

#: presale/views/user.py:78
msgid ""
"If there were any orders by this user, they will receive an email with their "
"order codes."
msgstr ""
"Pokud tento uživatel vytvořil nějaké objednávky, obdrží e-mail s kódy svých "
"objednávek."

#: presale/views/waiting.py:89
msgid "Waiting lists are disabled for this event."
msgstr "Čekací listiny jsou pro tuto akci vypnuté."

#: presale/views/waiting.py:93
