msgstr "Typ přednášky s tímto názvem už máte!"

#: orga/forms/cfp.py:489
#, python-brace-format
msgid "You can create an access code <a href=\"{url}\">here</a>."
msgstr "Přístupový kód můžete vytvořit <a href=\"{url}\">zde</a>."

#: orga/forms/cfp.py:498
msgid "You already have a track by this name!"
msgstr "Track s tímto názvem už máte!"

#: orga/forms/cfp.py:550
#, python-brace-format
msgid "Access code for the {event} CfP"
msgstr "Přístupový kód pro CfP události {event}"

#: orga/forms/cfp.py:554
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"This is an access code for the {event} CfP."
msgstr ""
"Zdravíme!\n"
"\n"
"Toto je přístupový kód pro CfP události {event}."

#: orga/forms/cfp.py:564
#, python-brace-format
msgid "It will allow you to submit a proposal to the “{track}” track."
msgstr "Dovolí vám odeslat přihlášku do tracku „{track}“."

#: orga/forms/cfp.py:571
msgid "It will allow you to submit a proposal to our CfP."
msgstr "Dovolí vám odeslat přihlášku do našeho CfP."

#: orga/forms/cfp.py:575
#, python-brace-format
msgid "This access code is valid until {date}."
msgstr "Tento přístupový kód je platný do {date}."

#: orga/forms/cfp.py:582
#, python-brace-format
msgid "The code can be redeemed multiple times ({num})."
msgstr "Tento kód je možné použít několikrát ({num})."

#: orga/forms/cfp.py:584
#, python-brace-format
msgid ""
"\n"
"Please follow this URL to use the code:\n"
"\n"
"  {url}\n"
"\n"
"I’m looking forward to your proposal!\n"
"{name}"
msgstr ""
"\n"
"Pro použití kódu prosím navštivte tuto URL adresu:\n"
"\n"
"  {url}\n"
"\n"
"Těšíme se na vaši přihlášku.\n"
"{name}"

#: orga/forms/cfp.py:615
msgid "Accepted or confirmed speakers"
msgstr "Přijatí a potvrzení přednášející"

#: orga/forms/cfp.py:616
msgid "Confirmed speakers"
msgstr "Potvrzení přednášející"

#: orga/forms/cfp.py:675
msgid "If you select no custom field, all will be used."
msgstr "Pokud není vybráno žádné vlastní pole, použijí se všechna."

#: orga/forms/event.py:36
msgid "Grid"
msgstr "Mřížka"

#: orga/forms/event.py:46
msgid "You can type in your CSS instead of uploading it, too."
msgstr "Své CSS můžete také přímo zadat místo jeho nahrávání."

#: orga/forms/event.py:56
msgid "Show schedule publicly"
msgstr "Zobrazit program veřejně"

#: orga/forms/event.py:57
msgid ""
"Unset to hide your schedule, e.g. if you want to use the HTML export "
"exclusively."
msgstr ""
"Zrušte výběr pro skrytí programu, např. pokud chcete použít výhradně HTML "
"export."

#: orga/forms/event.py:66
msgid "Show featured sessions"
msgstr "Zobrazit vybrané přednášky"

#: orga/forms/event.py:69
msgid "Until the first schedule is released"
msgstr "Do vydání první verze programu"

#: orga/forms/event.py:73
msgid ""
"Marking sessions as “featured” is a good way to show them before the first "
"schedule release, or to highlight them once the schedule is visible."
msgstr ""
"Označení přednášek jako „vybrané“ je dobrý způsob jako je ukázat před "
"vydáním první verze programu, nebo pro jejich zvýraznění ve zveřejněném "
"programu."

#: orga/forms/event.py:78
msgid "Enable anonymous feedback"
msgstr "Povolit anonymní hodnocení"

#: orga/forms/event.py:79
msgid "Attendees will be able to send in feedback after a session is over."
msgstr "Účastníci budou moci odesílat hodnocení přednášek po jejich skončení."

#: orga/forms/event.py:83 orga/forms/event.py:378
msgid "Activate most popular session feature"
msgstr ""

#: orga/forms/event.py:84 orga/forms/event.py:379
msgid ""
"Enables session popularity (favourites) counts and sorting options in the "
"schedule webapp."
msgstr ""

#: orga/forms/event.py:88 orga/forms/event.py:383
msgid "Show popularity on calendar view"
msgstr ""

#: orga/forms/event.py:89 orga/forms/event.py:384
msgid ""
"Shows favourite counts on session cards in the calendar/grid view. Only used "
"if popularity is enabled."
msgstr ""

#: orga/forms/event.py:93 orga/forms/event.py:388
msgid "Show popularity on list view"
msgstr ""

#: orga/forms/event.py:94 orga/forms/event.py:389
msgid ""
"Shows favourite counts on session cards in the list view. Only used if "
"popularity is enabled."
msgstr ""

#: orga/forms/event.py:98
msgid "Generate HTML export on schedule release"
msgstr "Generovat HTML export při zveřejnění programu"

#: orga/forms/event.py:99
msgid ""
"The static HTML export will be provided as a .zip archive on the schedule "
"export page."
msgstr ""
"Statický HTML export bude dostupný jako archiv ZIP na stránce exportu "
"programu."

#: orga/forms/event.py:103
msgid "HTML Export URL"
msgstr "URL adresa HTML exportu"

#: orga/forms/event.py:105
msgid ""
"If you publish your schedule via the HTML export, you will want the correct "
"absolute URL to be set in various places. Please only set this value once "
"you have published your schedule. Should end with a slash."
msgstr ""
"Pokud zveřejníte program formou HTML exportu, upravte absolutní URL, která "
"bude na několika místech použita. Nastavte tuto hodnotu jen po zveřejnění "
"programu. Měla by končit lomítkem."

#: orga/forms/event.py:117
msgid "Ask search engines not to index the event pages"
msgstr "Požádat vyhledávače, aby stránky události neindexovaly"

#: orga/forms/event.py:126
#, python-brace-format
msgid "You can find the page <a {href}>here</a>."
msgstr "Stránku najdete <a {href}>tady</a>."

#: orga/forms/event.py:191
msgid ""
"Reply-To address. If this setting is empty and you have no custom sender, "
"your event email address will be used as Reply-To address."
msgstr ""
"Adresa pro odpověď. Pokud je toto nastavení prázdné a nezadáte vlastního "
"odesílatele, bude jako adresa pro odpověď použita e-mailová adresa události."

#: orga/forms/event.py:196
msgid "Mail subject prefix"
msgstr "Prefix předmětu e-mailu"

#: orga/forms/event.py:197
msgid "The prefix will be prepended to outgoing mail subjects in [brackets]."
msgstr ""
"Prefix bude přidán na začátek předmětu odchozích e-mailových zpráv v "
"[závorkách]."

#: orga/forms/event.py:201
msgid "Mail signature"
msgstr "Podpis e-mailu"

#: orga/forms/event.py:202
msgid "The signature will be added to outgoing mails, preceded by “-- ”. "
msgstr ""
"Podpis bude přidán do odchozích e-mailů, před který bude vloženo „-- “. "

#: orga/forms/event.py:208
msgid "Use custom SMTP server"
msgstr "Použít vlastní SMTP server"

#: orga/forms/event.py:209
msgid ""
"All mail related to your event will be sent over the SMTP server specified "
"by you."
msgstr ""
"Všechny e-maily týkající se vaší události budou odesílány pomocí vámi "
"zvoleného SMTP serveru."

#: orga/forms/event.py:214
msgid "Sender address for outgoing emails."
msgstr "Adresa odesílatele odchozí pošty."

#: orga/forms/event.py:232
#, python-brace-format
msgid ""
"The password contains unsupported letters. Please only use characters A-Z, a-"
"z, 0-9, and common special characters ({characters})."
msgstr ""
"Heslo obsahuje nepodporovaná písmena. Používejte prosím pouze znaky A-Z, a-"
"z, 0-9 a běžné speciální znaky ({characters})."

#: orga/forms/event.py:270
msgid "You have to provide a sender address if you use a custom SMTP server."
msgstr "Při použití vlastního SMTP serveru je nutné zadat adresu odesílatele."

#: orga/forms/event.py:290
msgid ""
"You have to activate either SSL or STARTTLS security if you use a non-local "
"mailserver due to data protection reasons. Your administrator can add an "
"instance-wide bypass. If you use this bypass, please also adjust your "
"Privacy Policy."
msgstr ""
"Pokud nepoužíváte místní poštovní server, z důvodu ochrany dat musíte "
"aktivovat zabezpečení buď pomocí SSL nebo STARTTLS. Váš správce může přidat "
"výjimku na úrovni celé instance. V takovém případě také prosím upravte "
"Zásady ochrany osobních údajů."

#: orga/forms/event.py:321
msgid "Enable submission comments"
msgstr "Povolit komentáře k přihláškám"

#: orga/forms/event.py:322
msgid ""
"Allow organizers and reviewers to comment on submissions, separate from "
"reviews."
msgstr ""
"Umožnit organizátorům a recenzentům komentovat přihlášky nezávisle na "
"recenzích."

#: orga/forms/event.py:325
msgid "Require a review score"
msgstr "Vyžadovat skóre"

#: orga/forms/event.py:326
msgid "Require a review text"
msgstr "Vyžadovat text"

#: orga/forms/event.py:328
msgid "Score display"
msgstr "Zobrazení skóre"

#: orga/forms/event.py:331
msgid "Text and score, e.g “Good (3)”"
msgstr "Text a skóre, např. „Dobré (3)“"

#: orga/forms/event.py:332
msgid "Score and text, e.g “3 (good)”"
msgstr "Skóre a text, např. „3 (dobré)“"

#: orga/forms/event.py:333
msgid "Just scores"
