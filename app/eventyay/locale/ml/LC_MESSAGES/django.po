msgstr "ഗിഫ്റ്റ് കാർഡ് ഇറക്കാൻ ഉപയോഗിച്ചിരിക്കുന്ന സ്ഥാനത്തിന്റെ വില മാറ്റാനാകില്ല."

#: base/services/orders.py:2123
#, python-brace-format
msgid ""
"A position can not be canceled since the gift card {card} purchased in this "
