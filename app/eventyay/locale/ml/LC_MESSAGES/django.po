#: base/reldate.py:203 base/reldate.py:296
msgid "Relative date:"
msgstr "ആപേക്ഷിക തീയതി:"

#: base/reldate.py:204
msgid "Relative time:"
msgstr "ആപേക്ഷിക സമയം:"

#: base/reldate.py:212 base/reldate.py:299
msgid "Not set"
msgstr "സജ്ജീകരിച്ചിട്ടില്ല"

#: base/secrets.py:95
msgid "Random (default, works with all apps in the ecosystem)"
msgstr "ക്രമരഹിതം (ഡീഫോൾട്ട്, ഇക്കോസിസ്റ്റത്തിലുള്ള എല്ലാ ആപ്പുകളിലും പ്രവർത്തിക്കും)"

#: base/secrets.py:134
msgid ""
"signature scheme 1 (for very large events, does not work on all apps in the "
"ecosystem and changes semantics of offline scanning – please refer to "
"documentation or support for details)"
msgstr ""
"സിഗ്നേച്ചർ സ്കീം 1 (വളരെ വലിയ ഇവന്റുകൾക്കായി; ഇക്കോസിസ്റ്റത്തിലുള്ള എല്ലാ ആപ്പുകളിലും "
"പ്രവർത്തിക്കില്ല, ഓഫ്ലൈൻ സ്കാനിംഗിന്റെ അർത്ഥവ്യവസ്ഥ മാറ്റും — വിശദാംശങ്ങൾക്കായി "
"ഡോക്യുമെന്റേഷൻ അല്ലെങ്കിൽ പിന്തുണ കാണുക)"

#: base/services/cancelevent.py:271 base/services/cancelevent.py:340
msgid "Event canceled"
msgstr "ഇവന്റ് റദ്ദാക്കി"

#: base/services/cart.py:65 base/services/orders.py:113
msgid ""
"We were not able to process your request completely as the server was too "
"busy. Please try again."
msgstr ""
"സർവർ വളരെ തിരക്കായതിനാൽ അഭ്യർത്ഥന പൂർണ്ണമായി പ്രോസസ് ചെയ്യാൻ കഴിഞ്ഞില്ല. വീണ്ടും ശ്രമിക്കുക."

#: base/services/cart.py:66 presale/views/cart.py:206
msgid "You did not select any products."
msgstr "ഉൽപ്പന്നങ്ങളൊന്നും തിരഞ്ഞെടുക്കപ്പെട്ടില്ല."

#: base/services/cart.py:67
msgid "Unknown cart position."
msgstr "അജ്ഞാത കാർട്ട് സ്ഥാനം."

#: base/services/cart.py:68
msgctxt "subevent"
msgid "No date was specified."
msgstr "തീയതി വ്യക്തമാക്കിയിട്ടില്ല."

#: base/services/cart.py:69
msgid "You selected a product which is not available for sale."
msgstr "വിൽപ്പനയ്ക്ക് ലഭ്യമല്ലാത്ത ഒരു ഉൽപ്പന്നം തിരഞ്ഞെടുക്കപ്പെട്ടു."

#: base/services/cart.py:70
msgid ""
"Some of the products you selected are no longer available. Please see below "
"for details."
msgstr "തിരഞ്ഞെടുക്കപ്പെട്ട ചില ഉൽപ്പന്നങ്ങൾ ഇനി ലഭ്യമല്ല. വിശദാംശങ്ങൾക്കായി താഴെ കാണുക."

#: base/services/cart.py:72
msgid ""
"Some of the products you selected are no longer available in the quantity "
"you selected. Please see below for details."
msgstr ""
"തിരഞ്ഞെടുക്കപ്പെട്ട ചില ഉൽപ്പന്നങ്ങൾ തിരഞ്ഞെടുക്കപ്പെട്ട അളവിൽ ഇനി ലഭ്യമല്ല. "
"വിശദാംശങ്ങൾക്കായി താഴെ കാണുക."

#: base/services/cart.py:75
#, python-format
msgid "You cannot select more than %s products per order."
msgstr "ഒരു ഓർഡറിന് പരമാവധി %s ഉൽപ്പന്നങ്ങൾ വരെ മാത്രമേ തിരഞ്ഞെടുക്കാനാകൂ."

#: base/services/cart.py:76
#, python-format
msgid ""
"You cannot select more than %(max)s products of the product %(product)s."
msgstr ""
"%(product)s എന്ന ഉൽപ്പന്നത്തിൽ പരമാവധി %(max)s എണ്ണം വരെ മാത്രമേ തിരഞ്ഞെടുക്കാനാകൂ."

#: base/services/cart.py:77
#, python-format
msgid ""
"You need to select at least %(min)s products of the product %(product)s."
msgstr "%(product)s എന്ന ഉൽപ്പന്നത്തിൽ കുറഞ്ഞത് %(min)s എണ്ണം തിരഞ്ഞെടുക്കണം."

#: base/services/cart.py:79
#, python-format
msgid ""
"We removed %(product)s from your cart as you can not buy less than %(min)s "
"items of it."
msgstr ""
"അതിൽ നിന്ന് %(min)s ഇനങ്ങളിൽ കുറവ് വാങ്ങാൻ കഴിയാത്തതിനാൽ കാർട്ടിൽ നിന്ന് %(product)s "
"നീക്കം ചെയ്തു."

#: base/services/cart.py:81 base/services/orders.py:114
msgid "The presale period for this event has not yet started."
msgstr "ഈ ഇവന്റിന്റെ പ്രീസെയിൽ കാലയളവ് ഇതുവരെ ആരംഭിച്ചിട്ടില്ല."

#: base/services/cart.py:82
msgid "The presale period for this event has ended."
msgstr "ഈ ഇവന്റിന്റെ പ്രീസെയിൽ കാലയളവ് അവസാനിച്ചു."

#: base/services/cart.py:83
msgid ""
"All payments for this event need to be confirmed already, so no new orders "
"can be created."
msgstr ""
"ഈ ഇവന്റിലെ എല്ലാ പേയ്മെന്റുകളും ഇതിനകം സ്ഥിരീകരിക്കേണ്ടതിനാൽ പുതിയ ഓർഡറുകൾ "
"സൃഷ്ടിക്കാനാകില്ല."

#: base/services/cart.py:85
msgid ""
"The presale period for this event has not yet started. The affected "
"positions have been removed from your cart."
msgstr ""
"ഈ ഇവന്റിന്റെ പ്രീസെയിൽ കാലയളവ് ഇതുവരെ ആരംഭിച്ചിട്ടില്ല. ബാധിച്ച സ്ഥാനങ്ങൾ കാർട്ടിൽ നിന്ന് "
"നീക്കം ചെയ്തു."

#: base/services/cart.py:89 base/services/orders.py:140
msgid ""
"The presale period for one of the events in your cart has ended. The "
"affected positions have been removed from your cart."
msgstr ""
"കാർട്ടിലുള്ള ഇവന്റുകളിൽ ഒന്നിന്റെ പ്രീസെയിൽ കാലയളവ് അവസാനിച്ചു. ബാധിച്ച സ്ഥാനങ്ങൾ കാർട്ടിൽ "
"നിന്ന് നീക്കം ചെയ്തു."

#: base/services/cart.py:92
msgid "The entered price is to high."
msgstr "നൽകിയ വില വളരെ കൂടുതലാണ്."

#: base/services/cart.py:93
msgid "This voucher code is not known in our database."
msgstr "ഈ വൗച്ചർ കോഡ് ഞങ്ങളുടെ ഡാറ്റാബേസിൽ കണ്ടെത്തിയില്ല."

#: base/services/cart.py:94
msgid ""
"This voucher code has already been used the maximum number of times allowed."
msgstr "ഈ വൗച്ചർ കോഡ് അനുവദിച്ചിരിക്കുന്ന പരമാവധി തവണ ഇതിനകം ഉപയോഗിച്ചു."

#: base/services/cart.py:96
#, python-format
msgid ""
"This voucher code is currently locked since it is already contained in a "
"cart. This might mean that someone else is redeeming this voucher right now, "
"or that you tried to redeem it before but did not complete the checkout "
"process. You can try to use it again in %d minutes."
msgstr ""
"ഈ വൗച്ചർ കോഡ് ഇതിനകം ഒരു കാർട്ടിൽ ഉൾപ്പെട്ടിരിക്കുന്നതിനാൽ നിലവിൽ ലോക്ക് ചെയ്തിരിക്കുന്നു. "
"ആരെങ്കിലും ഇപ്പോൾ ഈ വൗച്ചർ റീഡീം ചെയ്യുകയായിരിക്കാം, അല്ലെങ്കിൽ മുമ്പ് റീഡീം ചെയ്യാൻ "
"ശ്രമിച്ചെങ്കിലും ചെക്ക്ഔട്ട് പ്രക്രിയ പൂർത്തിയാക്കിയില്ലായിരിക്കാം. %d മിനിറ്റിന് ശേഷം വീണ്ടും "
"ശ്രമിക്കാം."

#: base/services/cart.py:101
#, python-format
msgid "This voucher code can only be redeemed %d more times."
msgstr "ഈ വൗച്ചർ കോഡ് ഇനി %d തവണ മാത്രമേ റീഡീം ചെയ്യാൻ കഴിയൂ."

#: base/services/cart.py:103
msgid ""
"You already used this voucher code. Remove the associated line from your "
"cart if you want to use it for a different product."
msgstr ""
"ഈ വൗച്ചർ കോഡ് ഇതിനകം ഉപയോഗിച്ചു. മറ്റൊരു ഉൽപ്പന്നത്തിന് ഉപയോഗിക്കണമെങ്കിൽ കാർട്ടിലെ "
"ബന്ധപ്പെട്ട വരി നീക്കം ചെയ്യുക."

#: base/services/cart.py:106
msgid "This voucher is expired."
msgstr "ഈ വൗച്ചർ കാലഹരണപ്പെട്ടു."

#: base/services/cart.py:107
msgid "This voucher is not valid for this product."
msgstr "ഈ വൗച്ചർ ഈ ഉൽപ്പന്നത്തിന് സാധുവല്ല."

#: base/services/cart.py:108
msgid "This voucher is not valid for this seat."
msgstr "ഈ വൗച്ചർ ഈ സീറ്റിന് സാധുവല്ല."

#: base/services/cart.py:110
msgid ""
"We did not find any position in your cart that we could use this voucher "
"for. If you want to add something new to your cart using that voucher, you "
"can do so with the voucher redemption option on the bottom of the page."
msgstr ""
"ഈ വൗച്ചർ ഉപയോഗിക്കാൻ കഴിയുന്ന ഒരു ഇനം കാർട്ടിൽ കണ്ടെത്തിയില്ല. ഈ വൗച്ചർ ഉപയോഗിച്ച് "
"കാർട്ടിൽ പുതിയതായി എന്തെങ്കിലും ചേർക്കണമെങ്കിൽ, പേജിന്റെ അടിഭാഗത്തിലുള്ള വൗച്ചർ റീഡംപ്ഷൻ "
"ഓപ്ഷൻ ഉപയോഗിക്കാം."

#: base/services/cart.py:114
msgid "Your voucher is valid for a product that is currently not for sale."
msgstr "വിൽപ്പനയിലില്ലാത്ത ഒരു ഉൽപ്പന്നത്തിന് വൗച്ചർ സാധുവാണ്."

#: base/services/cart.py:115
msgctxt "subevent"
msgid "This voucher is not valid for this event date."
msgstr "ഈ വൗച്ചർ ഈ ഇവന്റ് തീയതിക്ക് സാധുവല്ല."

#: base/services/cart.py:116
msgid "You need a valid voucher code to order this product."
msgstr "ഈ ഉൽപ്പന്നം ഓർഡർ ചെയ്യാൻ സാധുവായ വൗച്ചർ കോഡ് ആവശ്യമാണ്."

#: base/services/cart.py:117
msgctxt "subevent"
msgid "The selected event date is not active."
msgstr "തിരഞ്ഞെടുത്ത ഇവന്റ് തീയതി സജീവമല്ല."

#: base/services/cart.py:118
msgid "You can not select an add-on for the selected product."
msgstr "തിരഞ്ഞെടുത്ത ഉൽപ്പന്നത്തിന് ഒരു ആഡ്-ഓൺ തിരഞ്ഞെടുക്കാൻ കഴിയില്ല."

#: base/services/cart.py:119
msgid "You can not select two variations of the same add-on product."
msgstr "അതേ ആഡ്-ഓൺ ഉൽപ്പന്നത്തിന്റെ രണ്ട് വകഭേദങ്ങൾ തിരഞ്ഞെടുക്കാൻ കഴിയില്ല."

#: base/services/cart.py:120
#, python-format
msgid ""
"You can select at most %(max)s add-ons from the category %(cat)s for the "
"product %(base)s."
msgstr ""
"ഉൽപ്പന്നം %(base)s ന്, വിഭാഗം %(cat)s ൽ നിന്ന് പരമാവധി %(max)s ആഡ്-ഓണുകൾ വരെ "
"തിരഞ്ഞെടുക്കാം."

#: base/services/cart.py:122
#, python-format
msgid ""
"You need to select at least %(min)s add-ons from the category %(cat)s for "
"the product %(base)s."
msgstr ""
"ഉൽപ്പന്നം %(base)s ന്, വിഭാഗം %(cat)s ൽ നിന്ന് കുറഞ്ഞത് %(min)s ആഡ്-ഓണുകൾ തിരഞ്ഞെടുക്കണം."

#: base/services/cart.py:125
#, python-format
msgid ""
"You can select every add-ons from the category %(cat)s for the product "
"%(base)s at most once."
msgstr ""
"ഉൽപ്പന്നം %(base)s ന്, വിഭാഗം %(cat)s ൽ നിന്നുള്ള ഓരോ ആഡ്-ഓണും പരമാവധി ഒരിക്കൽ മാത്രമേ "
"തിരഞ്ഞെടുക്കാനാകൂ."

#: base/services/cart.py:127
msgid ""
"One of the products you selected can only be bought as an add-on to another "
"project."
msgstr ""
"തിരഞ്ഞെടുത്ത ഉൽപ്പന്നങ്ങളിലൊന്ന് മറ്റൊരു പദ്ധതിയിലേക്കുള്ള ആഡ്-ഓണായി മാത്രമേ വാങ്ങാൻ കഴിയൂ."

#: base/services/cart.py:128
msgid "One of the products you selected can only be bought part of a bundle."
msgstr "തിരഞ്ഞെടുത്ത ഉൽപ്പന്നങ്ങളിലൊന്ന് ഒരു ബണ്ടിലിന്റെ ഭാഗമായി മാത്രമേ വാങ്ങാൻ കഴിയൂ."

#: base/services/cart.py:130
msgid "Please select a valid seat."
msgstr "സാധുവായ ഒരു സീറ്റ് തിരഞ്ഞെടുക്കുക."

#: base/services/cart.py:131
msgid "You can not select a seat for this position."
msgstr "ഈ സ്ഥാനത്തിനായി ഒരു സീറ്റ് തിരഞ്ഞെടുക്കാൻ കഴിയില്ല."

#: base/services/cart.py:133
msgid "You can not select the same seat multiple times."
msgstr "അതേ സീറ്റ് പല തവണ തിരഞ്ഞെടുക്കാൻ കഴിയില്ല."

#: base/services/cart.py:135
msgid ""
"You entered a gift card instead of a voucher. Gift cards can be entered "
"later on when you're asked for your payment details."
msgstr ""
"വൗച്ചറിന് പകരം ഗിഫ്റ്റ് കാർഡാണ് നൽകിയിരിക്കുന്നത്. പേയ്‌മെന്റ് വിവരങ്ങൾ ചോദിക്കുമ്പോൾ ഗിഫ്റ്റ് "
"കാർഡുകൾ പിന്നീട് നൽകാം."

#: base/services/cart.py:139
msgid ""
"Only one ticket per user is allowed for a product in your cart. You already "
"have a ticket."
msgstr ""
"കാർട്ടിലുള്ള ഒരു ഉൽപ്പന്നത്തിന് ഓരോ ഉപയോക്താവിനും ഒരു ടിക്കറ്റ് മാത്രമേ അനുവദിക്കൂ. ഇതിനകം ഒരു "
"ടിക്കറ്റ് ഉണ്ട്."

#: base/services/cart.py:140
msgid ""
"Only one ticket per user is allowed for this product. Quantity has been "
"adjusted to 1."
msgstr ""
"ഈ ഉൽപ്പന്നത്തിന് ഓരോ ഉപയോക്താവിനും ഒരു ടിക്കറ്റ് മാത്രമേ അനുവദിക്കൂ. എണ്ണം 1 ആയി ക്രമീകരിച്ചു."

#: base/services/checkin.py:409
msgid "This order position has been canceled."
msgstr "ഈ ഓർഡർ സ്ഥാനം റദ്ദാക്കി."

#: base/services/checkin.py:430
msgid "This order position has an invalid product for this check-in list."
msgstr "ഈ ഓർഡർ സ്ഥാനത്തിനായി ഈ ചെക്ക്-ഇൻ പട്ടികയിൽ അസാധുവായ ഒരു ഉൽപ്പന്നം ഉണ്ട്."

#: base/services/checkin.py:435
