#: base/configurations/default_setting.py:1844
#, python-brace-format
msgid ""
"Hello,\n"
"\n"
"you submitted yourself to the waiting list for {event},\n"
"for the product {product}.\n"
"\n"
"We now have a ticket ready for you! You can redeem it in our ticket shop\n"
"within the next {hours} hours by entering the following voucher code:\n"
"\n"
"{code}\n"
"\n"
"Alternatively, you can just click on the following link:\n"
"\n"
"{url}\n"
"\n"
"Please note that this link is only valid within the next {hours} hours!\n"
"We will reassign the ticket to the next person on the list if you do not\n"
"redeem the voucher within that timeframe.\n"
"\n"
"Best regards,\n"
"Your {event} team"
msgstr ""
"ഹലോ,\n"
"\n"
"{event} നുള്ള വെയ്റ്റിംഗ് ലിസ്റ്റിലേക്ക്, {product} ഉൽപ്പന്നത്തിനായി, ചേർന്നിരിക്കുന്നു.\n"
"\n"
"ഇപ്പോൾ നിങ്ങള്ക്കായി ഒരു ടിക്കറ്റ് തയ്യാറാണ്! താഴെ നൽകിയിരിക്കുന്ന വൗച്ചർ കോഡ് നൽകി അടുത്ത "
"{hours} മണിക്കൂറിനകം ടിക്കറ്റ് ഷോപ്പിൽ നിന്ന് റീഡീം ചെയ്യാം:\n"
"\n"
"{code}\n"
"\n"
"മറ്റൊരു മാർഗമായി, താഴെയുള്ള ലിങ്കിൽ ക്ലിക്ക് ചെയ്യാം:\n"
"\n"
"{url}\n"
"\n"
"ഈ ലിങ്ക് അടുത്ത {hours} മണിക്കൂറിനകം മാത്രമേ സാധുവാകൂ എന്ന് ശ്രദ്ധിക്കുക!\n"
"ആ സമയപരിധിക്കുള്ളിൽ വൗച്ചർ റീഡീം ചെയ്തില്ലെങ്കിൽ ടിക്കറ്റ് പട്ടികയിലെ അടുത്ത വ്യക്തിക്ക് "
"പുനർനിർദേശിക്കും.\n"
"\n"
"ആദരപൂർവം,\n"
"നിങ്ങളുടെ {event} ടീം"

