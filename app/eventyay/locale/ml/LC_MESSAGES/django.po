msgstr "ഇമെയിലുകൾ അയയ്‌ക്കുക"

#: orga/views/mails.py:149
msgid ""
"This mail either does not exist or cannot be sent because it was sent "
"already."
msgstr "ഈ മെയിൽ നിലവിലില്ല, അല്ലെങ്കിൽ ഇതിനകം അയച്ചതിനാൽ അയയ്‌ക്കാൻ കഴിയില്ല."

#: orga/views/mails.py:153
msgid "This mail had been sent already."
msgstr "ഈ മെയിൽ ഇതിനകം അയച്ചിട്ടുണ്ട്."

#: orga/views/mails.py:161
msgid "The mail has been sent."
msgstr "മെയിൽ അയച്ചു."

#: orga/views/mails.py:182
#, python-brace-format
msgid "{count} mails have been sent."
msgstr "{count} മെയിലുകൾ അയച്ചു."

#: orga/views/mails.py:212 plugins/sendmail/views.py:398
#, python-brace-format
msgid "Do you really want to delete this mail?"
msgid_plural "Do you really want to purge {count} mails?"
msgstr[0] "ഈ മെയിൽ ഇല്ലാതാക്കണമെന്ന് ഉറപ്പാണോ?"
msgstr[1] "{count} മെയിലുകൾ പൂർണ്ണമായി നീക്കം ചെയ്യണമെന്ന് ഉറപ്പാണോ?"

#: orga/views/mails.py:224
msgid ""
"This mail either does not exist or cannot be discarded because it was sent "
"already."
msgstr "ഈ മെയിൽ നിലവിലില്ല, അല്ലെങ്കിൽ ഇതിനകം അയച്ചതിനാൽ ഉപേക്ഷിക്കാൻ കഴിയില്ല."

#: orga/views/mails.py:235
#, python-brace-format
msgid "The mail has been discarded."
msgid_plural "{count} mails have been discarded."
msgstr[0] "മെയിൽ ഉപേക്ഷിച്ചു."
msgstr[1] "{count} മെയിലുകൾ ഉപേക്ഷിച്ചു."

#: orga/views/mails.py:251
#, python-brace-format
msgid "Do you really want to purge {count} mails?"
msgstr "{count} മെയിലുകൾ പൂർണ്ണമായി നീക്കം ചെയ്യണമെന്ന് ഉറപ്പാണോ?"

#: orga/views/mails.py:268
#, python-brace-format
msgid "{count} mails have been purged."
msgstr "{count} മെയിലുകൾ പൂർണ്ണമായി നീക്കം ചെയ്തു."

#: orga/views/mails.py:299
msgid "The email has been sent."
msgstr "ഇമെയിൽ അയച്ചു."

#: orga/views/mails.py:303
msgid ""
"The email has been saved. When you send it, the updated text will be used."
msgstr "ഇമെയിൽ സേവ് ചെയ്‌തു. അയയ്‌ക്കുമ്പോൾ അപ്‌ഡേറ്റ് ചെയ്ത വാചകം ഉപയോഗിക്കും."

#: orga/views/mails.py:317
msgid "The mail has been copied, you can edit it now."
msgstr "മെയിൽ പകർത്തി; ഇപ്പോൾ എഡിറ്റ് ചെയ്യാം."

#: orga/views/mails.py:379
msgid "There are no recipients matching this selection."
msgstr "ഈ തിരഞ്ഞെടുപ്പുമായി പൊരുത്തപ്പെടുന്ന സ്വീകരിക്കുന്നവർ ഇല്ല."

#: orga/views/mails.py:410 orga/views/mails.py:477
#, python-brace-format
msgid "{count} emails have been sent."
msgstr "{count} ഇമെയിലുകൾ അയച്ചു."

#: orga/views/mails.py:489
msgid ""
"The template has been saved - note that already pending emails that are "
"based on this template will not be changed!"
msgstr ""
"ടെംപ്ലേറ്റ് സേവ് ചെയ്തു – എന്നാൽ ഇതിനകം പണ്ടിംഗ് ആയിട്ടുള്ള, ഈ ടെംപ്ലേറ്റിനെ "
"അടിസ്ഥാനമാക്കിയിരിക്കുന്ന ഇമെയിലുകൾ മാറ്റപ്പെടില്ലെന്ന് ശ്രദ്ധിക്കുക!"

#: orga/views/mails.py:504
msgid "New email template"
msgstr "പുതിയ ഇമെയിൽ ടെംപ്ലേറ്റ്"

#: orga/views/mails.py:505
#: plugins/sendmail/templates/pretixplugins/sendmail/mail_templates.html:5
#: plugins/sendmail/templates/pretixplugins/sendmail/mail_templates.html:10
msgid "Email templates"
msgstr "ഇമെയിൽ ടെംപ്ലേറ്റുകൾ"

#: orga/views/organizer.py:66
msgid ""
"ALL related data for ALL events, such as proposals, and speaker profiles, "
"and uploads, will also be deleted and cannot be restored."
msgstr ""
"പ്രസ്താവനകൾ, പ്രഭാഷക പ്രൊഫൈലുകൾ, അപ്‌ലോഡുകൾ എന്നിവ ഉൾപ്പെടെ, എല്ലാ ഇവന്റുകളുമായി ബന്ധപ്പെട്ട "
"എല്ലാ ഡാറ്റയും ഇല്ലാതാക്കപ്പെടും; അത് പുനഃസ്ഥാപിക്കാൻ കഴിയില്ല."

#: orga/views/organizer.py:90
msgid "The organizer and all related data have been deleted."
msgstr "ഓർഗനൈസറും അനുബന്ധമായ എല്ലാ ഡാറ്റയും ഇല്ലാതാക്കി."

#: orga/views/person.py:69
msgid ""
"This is your new API token. Please make sure to save it, as it will not be "
"shown again:"
msgstr ""
"ഇതാണ് പുതിയ API ടോക്കൺ. ഇത് വീണ്ടും കാണിക്കുകയില്ലാത്തതിനാൽ, സേവ് ചെയ്തുവെന്ന് ഉറപ്പാക്കുക:"

#: orga/views/person.py:78
msgid "The API token has been upgraded."
msgstr "API ടോക്കൺ അപ്‌ഗ്രേഡ് ചെയ്തു."

#: orga/views/person.py:104
msgid "You are now an administrator instead of a superuser."
msgstr "ഇപ്പോൾ സൂപ്പർയൂസർക്ക് പകരം അഡ്മിനിസ്ട്രേറ്ററായി മാറ്റി."

#: orga/views/review.py:283
#, python-brace-format
msgid ""
"Success! {accepted} proposals were accepted, {rejected} proposals were "
"rejected."
msgstr "വിജയം! {accepted} പ്രസ്താവനകൾ അംഗീകരിച്ചു, {rejected} പ്രസ്താവനകൾ നിരസിച്ചു."

#: orga/views/review.py:287
#, python-brace-format
msgid "We were unable to change the state of {count} proposals."
msgstr "{count} പ്രസ്താവനകളുടെ നില മാറ്റാൻ കഴിഞ്ഞില്ല."

#: orga/views/review.py:294
#, python-brace-format
msgid "We were unable to change the state of all {count} proposals."
msgstr "എല്ലാ {count} പ്രസ്താവനകളുടെയും നില മാറ്റാൻ കഴിഞ്ഞില്ല."

#: orga/views/review.py:587
msgid "Nice, you have no proposals left to review!"
msgstr "നന്നായി, ഇനി റിവ്യൂ ചെയ്യാൻ പ്രസ്താവനകളൊന്നും ബാക്കിയില്ല!"

#: orga/views/review.py:599
msgid "Your review"
msgstr "റിവ്യൂ"

#: orga/views/review.py:608
msgid "The review has been deleted."
msgstr "റിവ്യൂ ഇല്ലാതാക്കി."

#: orga/views/review.py:637
#, python-format
msgid ""
"Do you really want to regenerate %(count)s acceptance and rejection emails? "
"They will be placed in the outbox and not sent out directly."
msgstr ""
"%(count)s അംഗീകാരവും നിരസണവും അറിയിക്കുന്ന ഇമെയിലുകൾ വീണ്ടും സൃഷ്ടിക്കണോ? അവ ഔട്ട്‌ബോക്സിൽ "
"ഇടും; നേരിട്ട് അയക്കില്ല."

#: orga/views/review.py:650
#, python-brace-format
msgid "{count} emails were generated and placed in the outbox."
msgstr "{count} ഇമെയിലുകൾ സൃഷ്ടിച്ച് ഔട്ട്‌ബോക്സിൽ ചേർത്തു."

#: orga/views/review.py:679
msgid "Assign reviewer teams"
msgstr "റിവ്യൂവർ ടീമുകൾ നിയോഗിക്കുക"

#: orga/views/review.py:680
msgid "Assign reviewers individually"
msgstr "റിവ്യൂവർമാരെ ഓരോരുത്തരായി നിയോഗിക്കുക"

#: orga/views/review.py:714
msgid "The reviewers were assigned successfully."
msgstr "റിവ്യൂവേഴ്‌സിനെ വിജയകരമായി നിയോഗിച്ചു."

#: orga/views/review.py:726 orga/views/schedule.py:91 orga/views/speaker.py:364
msgid "CSV/JSON exports"
msgstr "CSV/JSON എക്‌സ്‌പോര്‍ട്ടുകള്‍"

#: orga/views/review.py:739 orga/views/schedule.py:99 orga/views/speaker.py:372
msgid "No data to be exported"
msgstr "എക്‌സ്‌പോര്‍ട്ട് ചെയ്യാനുള്ള ഡാറ്റയില്ല"

#: orga/views/schedule.py:92 orga/views/speaker.py:365
msgid "More exports"
msgstr "കൂടുതല്‍ എക്‌സ്‌പോര്‍ട്ടുകള്‍"

#: orga/views/schedule.py:112
msgid "A new export is being generated and will be available soon."
msgstr "ഒരു പുതിയ എക്‌സ്‌പോര്‍ട്ട് സൃഷ്ടിച്ചുകൊണ്ടിരിക്കുകയാണ്; ഉടന്‍ ലഭ്യമാകും."

#: orga/views/schedule.py:119
msgid ""
"A new export will be generated on the next scheduled opportunity – please "
"contact your administrator for details."
msgstr ""
"അടുത്ത ഷെഡ്യൂള്‍ ചെയ്ത അവസരത്തില്‍ ഒരു പുതിയ എക്‌സ്‌പോര്‍ട്ട് സൃഷ്ടിക്കും – വിശദാംശങ്ങള്‍ക്ക് "
"അഡ്മിനിസ്ട്രേറ്ററെ ബന്ധപ്പെടുക."

#: orga/views/schedule.py:136
#, python-brace-format
msgid ""
"Could not find the current export, please try to regenerate it. ({error})"
msgstr "നിലവിലെ എക്‌സ്‌പോര്‍ട്ട് കണ്ടെത്താനായില്ല; വീണ്ടും സൃഷ്ടിക്കാന്‍ ശ്രമിക്കുക. ({error})"

#: orga/views/schedule.py:167
msgid "You have to provide a new, unique schedule version!"
msgstr "പുതിയതും പ്രത്യേകതയുള്ളതുമായ ഒരു ഷെഡ്യൂള്‍ പതിപ്പ് നല്‍കണം!"

#: orga/views/schedule.py:178
msgid "Talks must be published or in private test mode to release a schedule."
msgstr ""
"ഷെഡ്യൂള്‍ റിലീസ് ചെയ്യാന്‍ ടോക്കുകള്‍ പ്രസിദ്ധീകരിച്ചിരിക്കണം അല്ലെങ്കില്‍ സ്വകാര്യ ടെസ്റ്റ് "
"മോഡിലിരിക്കണം."

#: orga/views/schedule.py:187
msgid "Nice, your schedule has been released!"
msgstr "ശരി, ഷെഡ്യൂള്‍ റിലീസ് ചെയ്തു!"

#: orga/views/schedule.py:202
msgid ""
"Reset successful – start editing the schedule from your selected version!"
msgstr "റീസെറ്റ് വിജയകരം – തെരഞ്ഞെടുത്ത പതിപ്പില്‍നിന്ന് ഷെഡ്യൂള്‍ എഡിറ്റ് ചെയ്യുക!"

#: orga/views/schedule.py:205
msgid "Error retrieving the schedule version to reset to."
msgstr "റീസെറ്റ് ചെയ്യേണ്ട ഷെഡ്യൂള്‍ പതിപ്പ് ലഭ്യമാക്കുന്നതില്‍ പിശക്."

#: orga/views/schedule.py:253
msgid "You can only regenerate mails after the first schedule was released."
msgstr "ആദ്യ ഷെഡ്യൂള്‍ റിലീസ് ചെയ്തതിന് ശേഷമേ മെയിലുകള്‍ വീണ്ടും സൃഷ്ടിക്കാനാകൂ."

#: orga/views/schedule.py:491
msgid "The session has been scheduled."
msgstr "സെഷന്‍ ഷെഡ്യൂള്‍ ചെയ്തു."

#: orga/views/schedule.py:524
msgid "The selected room has been deleted."
msgstr "തിരഞ്ഞെടുത്ത മുറി ഇല്ലാതാക്കി."

#: orga/views/speaker.py:264
msgid ""
"Do your really want to reset this user’s password? They won’t be able to log "
"in until they set a new password."
msgstr ""
"ഈ ഉപയോക്താവിന്റെ പാസ്‌വേഡ് റീസെറ്റ് ചെയ്യണമെന്ന് ഉറപ്പാണോ? പുതിയ പാസ്‌വേഡ് സജ്ജമാക്കുന്നതുവരെ "
"ലോഗിന്‍ ചെയ്യാനാകില്ല."

#: orga/views/speaker.py:344
msgid "Speaker Information Notes"
msgstr "സ്പീക്കർ വിവര കുറിപ്പുകൾ"

#: orga/views/submission.py:167
msgid ""
"Somebody else was faster than you: this proposal was already in the state "
