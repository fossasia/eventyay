#: eventyay_common/templates/eventyay_common/event/live.html:159
#: orga/templates/orga/event/live.html:19
msgid "Talk status"
msgstr "Κατάσταση ομιλίας"

#: eventyay_common/templates/eventyay_common/event/live.html:163
#: orga/templates/orga/event/live.html:23
msgid "Your talk component may not be ready for release yet!"
msgstr ""
"Το στοιχείο ομιλίας σας μπορεί να μην είναι ακόμη έτοιμο για κυκλοφορία!"

#: eventyay_common/templates/eventyay_common/event/live.html:167
#: eventyay_common/templates/eventyay_common/event/live.html:177
#: orga/templates/orga/event/live.html:27
#: orga/templates/orga/event/live.html:37
