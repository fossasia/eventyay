msgstr ""
"Σφάλμα κατά την εισαγωγή της τιμής \"{value}\" για τη στήλη \"{column}\" στη "
"γραμμή \"{line}\": {message}"

#: base/services/orderimport.py:126
#, python-brace-format
msgid "Invalid data in row {row}: {message}"
