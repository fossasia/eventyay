msgstr ""
"Για να δημοσιεύσετε την εκδήλωσή σας, πρέπει πρώτα να επιλύσετε τα ακόλουθα "
"ζητήματα:"

#: eventyay_common/templates/eventyay_common/event/live.html:49
#: eventyay_common/templates/eventyay_common/event/live.html:57
msgid "Publish Event"
msgstr "Δημοσίευση εκδήλωσης"

#: eventyay_common/templates/eventyay_common/event/live.html:64
