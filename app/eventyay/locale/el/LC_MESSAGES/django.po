msgid "Price mode"
msgstr "Τρόπος τιμής"

#: base/models/vouchers.py:153 base/models/vouchers.py:578
msgid "Voucher value"
msgstr "Τιμή κουπονιού"

#: base/models/vouchers.py:166 control/forms/vouchers.py:31
msgid "This product is added to the user's cart if the voucher is redeemed."
msgstr ""
