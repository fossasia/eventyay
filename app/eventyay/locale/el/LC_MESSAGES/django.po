msgstr ""
"Δεν απαιτείται πληρωμή, καθώς αυτή η παραγγελία περιλαμβάνει μόνο προϊόντα "
"που είναι δωρεάν."

#: base/payment.py:921
msgid "Free of charge"
msgstr "Δωρεάν"

#: base/payment.py:949
msgid "Box office"
msgstr "Εκδοτήριο"

#: base/payment.py:992 base/payment.py:1011 plugins/manualpayment/apps.py:9
