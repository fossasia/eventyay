#: base/configurations/default_setting.py:2147
#: base/configurations/default_setting.py:2207 base/models/event.py:734
#: control/forms/organizer_forms/organizer_settings_form.py:35
msgid "Header image"
msgstr "Imatge de capçalera"

#: base/configurations/default_setting.py:2151 base/models/event.py:736
msgid ""
"This image appears at the top of all event pages, replacing the default "
"color or pattern. It is center-aligned and not stretched, ensuring the "
"middle part remains visible on smaller screens. We recommend an image at "
"least 1170 px wide and 120 px in height for best results."
msgstr ""
"Aquesta imatge apareix a la part superior de totes les pàgines de "
"l'esdeveniment, substituint el color o el patró predeterminat. Està centrada "
"i no s'estira, garantint que la part central es manté visible en pantalles "
"més petites. Recomanem una imatge d'almenys 1170 px d'amplada i 120 px "
"d'alçada per obtenir els millors resultats."

#: base/configurations/default_setting.py:2167 base/models/event.py:724
msgid "Logo"
msgstr "Logotip"

#: base/configurations/default_setting.py:2171
msgid ""
"When you upload a logo, the event name and date will not appear in the "
"header. The logo scales to 140 px in height while maintaining aspect ratio. "
"We recommend not using small details as it will be resized on smaller "
"screens."
msgstr ""
"Quan puges un logotip, el nom i la data de l'esdeveniment no apareixeran a "
"la capçalera. El logotip s'escala fins a 140 px d'alçada mantenint la "
"relació d'aspecte. Recomanem no utilitzar detalls petits, ja que es "
"redimensionarà en pantalles més petites."

#: base/configurations/default_setting.py:2188
#: base/configurations/default_setting.py:2228
msgid "Use header image in its full size"
msgstr "Fes servir la imatge de capçalera a mida completa"

#: base/configurations/default_setting.py:2189
#: base/configurations/default_setting.py:2229
msgid "We recommend to upload a picture at least 1170 pixels wide."
msgstr "Recomanem pujar una imatge d’almenys 1170 píxels d’ample."

#: base/configurations/default_setting.py:2198
msgid "Show event title even if a logo image is present"
msgstr ""
"Mostra el títol de l'esdeveniment encara que hi hagi una imatge de logotip"

#: base/configurations/default_setting.py:2199
msgid "The title will only be shown on the event front page."
msgstr "El títol només es mostrarà a la pàgina principal de l'esdeveniment."

#: base/configurations/default_setting.py:2211
msgid ""
"This image appears at the top of all organizer pages, replacing the default "
"color or pattern. It is center-aligned and not stretched, ensuring the "
"middle part remains visible on smaller screens. We recommend an image 1140 "
"px wide and 120 px in height (can be increased with the setting below)."
msgstr ""
"Aquesta imatge apareix a la part superior de totes les pàgines de "
"l'organitzador, substituint el color o el patró predeterminat. Està centrada "
"i no s'estira, garantint que la part central es manté visible en pantalles "
"més petites. Recomanem una imatge de 1140 px d'amplada i 120 px d'alçada (es "
"pot augmentar amb la configuració següent)."

#: base/configurations/default_setting.py:2237
msgid "Social media image"
msgstr "Imatge de xarxes socials"

#: base/configurations/default_setting.py:2241
msgid ""
"This image is used as a preview when sharing your event link on social "
"media. Facebook recommends a size of 1200 × 630 px, but some platforms such "
"as WhatsApp and Reddit display a square preview. Ensure the center area of "
"your image looks good in both formats. If no image is uploaded, the event "
"logo will be used instead."
msgstr ""
"Aquesta imatge s'utilitza com a previsualització quan comparteixes l'enllaç "
"del teu esdeveniment a les xarxes socials. Facebook recomana una mida de "
"1200 × 630 px, però algunes plataformes com WhatsApp i Reddit mostren una "
"previsualització quadrada. Assegura't que la zona central de la imatge es "
"vegi bé en tots dos formats. Si no es puja cap imatge, s'utilitzarà el "
"logotip de l'esdeveniment."

#: base/configurations/default_setting.py:2258
msgid "Logo image"
msgstr "Imatge del logo"

#: base/configurations/default_setting.py:2262
msgid "We will show your logo with a maximal height and width of 2.5 cm."
msgstr "Mostrarem el vostre logo amb una alçada i amplada màxima de 2,5 cm."

#: base/configurations/default_setting.py:2275 base/models/event.py:2917
msgid "Frontpage text"
msgstr "Text de la pàgina frontal"

#: base/configurations/default_setting.py:2283
#: base/configurations/default_setting.py:2401
msgid "Info text"
msgstr "Text d'informació"

#: base/configurations/default_setting.py:2287
#: base/configurations/default_setting.py:2404
msgid ""
"Not displayed anywhere by default, but if you want to, you can use this e.g. "
"in ticket templates."
msgstr ""
"No es mostra enlloc per defecte, però si vols, el pots fer servir, per "
"exemple, a les plantilles de tiquets."

#: base/configurations/default_setting.py:2297
msgid "Banner text (top)"
msgstr "Text del banner (a dalt)"

#: base/configurations/default_setting.py:2301
msgid ""
"This text will be shown above every page of your shop. Please only use this "
"for very important messages."
msgstr ""
"Aquest text es mostrarà a la part superior de cada pàgina de la teva botiga. "
"Si us plau, utilitza-ho només per a missatges molt importants."

#: base/configurations/default_setting.py:2312
msgid "Banner text (bottom)"
msgstr "Text del banner (a baix)"

#: base/configurations/default_setting.py:2316
msgid ""
"This text will be shown below every page of your shop. Please only use this "
"for very important messages."
msgstr ""
"Aquest text es mostrarà sota cada pàgina de la teva botiga. Si us plau, fes "
"servir això només per a missatges molt importants."

#: base/configurations/default_setting.py:2327
msgid "Voucher explanation"
msgstr "Explicació del val"

#: base/configurations/default_setting.py:2331
msgid ""
"This text will be shown next to the input for a voucher code. You can use it "
"e.g. to explain how to obtain a voucher code."
msgstr ""
"Aquest text es mostrarà al costat de l'entrada del codi del val. Ho podeu "
"utilitzar per explicar com obtenir un codi de val."

#: base/configurations/default_setting.py:2342
msgid "Attendee data explanation"
msgstr "Explicació de les dades dels assistents"

#: base/configurations/default_setting.py:2346
msgid ""
"This text will be shown above the questions asked for every admission "
"product. You can use it e.g. to explain why you need information from them."
msgstr ""
"Aquest text es mostrarà per sobre de les preguntes fetes per a cada producte "
"d'entrada. El podeu utilitzar, per exemple, per explicar per què necessiteu "
"informació d'ells."

#: base/configurations/default_setting.py:2357
msgid "Additional success message"
msgstr "Missatge d'èxit addicional"

#: base/configurations/default_setting.py:2359
msgid ""
"This message will be shown after an order has been created successfully. It "
"will be shown in additionalto the default text."
msgstr ""
"Aquest missatge es mostrarà després que s'hagi creat una comanda "
"correctament. Es mostrarà a més del text predeterminat."

#: base/configurations/default_setting.py:2373
msgid "Help text of the phone number field"
msgstr "Text d'ajuda del camp del número de telèfon"

#: base/configurations/default_setting.py:2381
msgid ""
"Make sure to enter a valid email address. We will send you an order "
"confirmation including a link that you need to access your order later."
msgstr ""
"Assegureu-vos de posar una adreça de correu vàlida. Us hi enviarem una "
"confirmació amb un enllaç que us farà falta per accedir a la comanda més "
"endavant."

#: base/configurations/default_setting.py:2389
msgid "Help text of the email field"
msgstr "Text d'ajuda del camp del correu electrònic"

#: base/configurations/default_setting.py:2414
msgid "Allow creating a new team during event creation"
msgstr "Permet crear un equip nou durant la creació de l'esdeveniment"

#: base/configurations/default_setting.py:2416
msgid ""
"Users that do not have access to all events under this organizer, must "
"select one of their teams to have access to the created event. This setting "
"allows users to create an event-specified team on-the-fly, even when they do "
"not have \"Can change teams and permissions\" permission."
msgstr ""
"Els usuaris que no tenen accés a tots els esdeveniments d'aquest "
"organitzador han de seleccionar un dels seus equips per tenir accés a "
"l'esdeveniment creat. Aquesta configuració permet als usuaris crear sobre la "
"marxa un equip específic per a l'esdeveniment, fins i tot quan no tenen el "
"permís \"Pot canviar equips i permisos\"."

