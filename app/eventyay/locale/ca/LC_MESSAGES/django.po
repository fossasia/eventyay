msgstr "S'ha publicat un nou programa de %(event_name)s"

#: agenda/templates/agenda/feed/description.html:10
#, python-format
msgid "The first %(event_name)s schedule has been released!"
msgstr "El primer programa de %(event_name)s ja està a punt!"

