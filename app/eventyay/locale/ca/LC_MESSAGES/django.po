"Hi!\n"
"You have been invited to the {name} event organizer team - Please click here "
"to accept:\n"
"\n"
"{invitation_link}\n"
"\n"
"See you there,\n"
"The {organizer} team"
msgstr ""
"Hola!\n"
"T'han convidat a l'equip d'organitzadors de l'esdeveniment {name} - Si us "
"plau, fes clic aquí per acceptar:\n"
"\n"
"{invitation_link}\n"
"\n"
"Fins aviat,\n"
"L'equip de {organizer}"

#: base/models/organizer.py:563
msgid "You have been invited to an organizer team"
msgstr "T'han convidat a un equip d'organitzadors"

