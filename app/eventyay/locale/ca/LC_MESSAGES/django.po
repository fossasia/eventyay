msgid "Audience feedback"
msgstr "Comentaris del públic"

#: cfp/templates/cfp/event/user_submission_edit.html:39
msgid "Attendees can leave feedback here after your session has taken place."
msgstr ""
"Els assistents poden deixar comentaris aquí després que la teva sessió hagi "
"tingut lloc."

#: cfp/templates/cfp/event/user_submission_edit.html:51
