#: base/services/mail.py:220
#, python-brace-format
msgid ""
"You are receiving this email because someone placed an order for {event} for "
"you."
msgstr "कोणीतरी तुमच्यासाठी {event} साठी ऑर्डर दिल्यामुळे हा ईमेल मिळत आहे."

#: base/services/mail.py:224 base/services/mail.py:245
#, python-brace-format
msgid ""
"You can view your order details at the following URL:\n"
"{orderurl}."
msgstr ""
"खालील URL वर ऑर्डर तपशील पाहता येतील:\n"
"{orderurl}."

#: base/services/mail.py:240
#, python-brace-format
msgid "You are receiving this email because you placed an order for {event}."
msgstr "{event} साठी ऑर्डर दिल्यामुळे हा ईमेल मिळत आहे."

