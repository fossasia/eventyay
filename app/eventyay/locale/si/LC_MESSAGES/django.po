#: orga/views/submission.py:1001
msgid "The comment has been deleted."
msgstr "අදහස මකා දමා ඇත."

#: orga/views/submission.py:1026
#, python-brace-format
msgid "Changed {count} proposal states."
msgstr "{count} යෝජනා තත්ත්වයන් වෙනස් කරන ලදී."

