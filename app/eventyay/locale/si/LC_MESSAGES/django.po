msgstr "\"Secret\"/\"Account Key\" තුළ පහත කේතය ඇතුළත් කරන්න:"

#: eventyay_common/templates/eventyay_common/account/2fa-confirm-totp.html:73
msgid "copy"
msgstr "පිටපත් කරන්න"

#: eventyay_common/templates/eventyay_common/account/2fa-confirm-totp.html:81
