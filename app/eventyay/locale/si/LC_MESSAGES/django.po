#: control/templates/pretixcontrol/vouchers/detail.html:97
msgid "Voucher history"
msgstr "වවුචර් ඉතිහාසය"

#: control/templates/pretixcontrol/vouchers/index.html:19
msgid "All vouchers"
msgstr "සියලුම වවුචර්"

#: control/templates/pretixcontrol/vouchers/index.html:24
