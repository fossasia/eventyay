#: control/templates/pretixcontrol/email/forgot.txt:1
#, python-format
msgid ""
"Hello,\n"
"\n"
"you requested a new password. Please go to the following page to reset your "
"password:\n"
"\n"
"%(url)s\n"
"\n"
"Best regards,\n"
"Your system team\n"
msgstr ""
"ہیلو،\n"
"\n"
"آپ نے نیا پاس ورڈ درخواست کیا تھا۔ براہِ کرم اپنا پاس ورڈ ری سیٹ کرنے کے لیے "
"درج ذیل صفحے پر جائیں:\n"
"\n"
"%(url)s\n"
"\n"
"نیک تمنائیں،\n"
"آپ کی سسٹم ٹیم\n"

#: control/templates/pretixcontrol/email/invitation.txt:1
#, python-format
msgid ""
"Hello,\n"
"\n"
"You have been added to the following event team:\n"
"\n"
"Organizer: %(organizer)s\n"
"Team: %(team)s\n"
"\n"
"Click the following link to view your team dashboard:\n"
"\n"
"%(url)s\n"
"\n"
"Best regards,\n"
"\n"
"Your event team\n"
msgstr ""
"ہیلو،\n"
"\n"
"آپ کو درج ذیل ایونٹ ٹیم میں شامل کیا گیا ہے:\n"
"\n"
"منتظم: %(organizer)s\n"
"ٹیم: %(team)s\n"
"\n"
"اپنا ٹیم ڈیش بورڈ دیکھنے کے لیے درج ذیل لنک پر کلک کریں:\n"
"\n"
"%(url)s\n"
"\n"
"نیک تمنائیں،\n"
"\n"
"آپ کی ایونٹ ٹیم\n"

#: control/templates/pretixcontrol/email/invitation.txt:15
#, python-format
msgid ""
"Hello,\n"
"\n"
"You have been invited to the following event team:\n"
"\n"
"Organizer: %(organizer)s\n"
"Team: %(team)s\n"
"\n"
"If you want to join that team, just click on the following link:\n"
"\n"
"%(url)s\n"
"\n"
"If you do not want to join, you can safely ignore or delete this email.\n"
"\n"
"Best regards,\n"
"\n"
"Your event team\n"
msgstr ""
"ہیلو،\n"
"\n"
"آپ کو درج ذیل ایونٹ ٹیم میں مدعو کیا گیا ہے:\n"
"\n"
"منتظم: %(organizer)s\n"
"ٹیم: %(team)s\n"
"\n"
"اگر ٹیم میں شامل ہونا چاہتے ہیں تو درج ذیل لنک پر کلک کریں:\n"
"\n"
"%(url)s\n"
"\n"
"اگر شامل نہیں ہونا چاہتے تو اس ای میل کو نظر انداز کر سکتے ہیں یا حذف کر "
"سکتے ہیں۔\n"
"\n"
"نیک تمنائیں،\n"
"\n"
"آپ کی ایونٹ ٹیم\n"

#: control/templates/pretixcontrol/email/security_notice.txt:1
#, python-format
msgid ""
"Hello,\n"
"\n"
"this is to inform you that the account information of your eventyay account "
"has been\n"
"changed. In particular, the following changes have been performed:\n"
"\n"
"%(messages)s\n"
"\n"
"If this change was not performed by you, please contact us immediately.\n"
"\n"
"You can review and change your account settings here:\n"
"\n"
"%(url)s\n"
"\n"
"Best regards,\n"
"Your system team\n"
msgstr ""
"ہیلو،\n"
"\n"
"اطلاع دی جاتی ہے کہ آپ کے eventyay اکاؤنٹ کی اکاؤنٹ معلومات میں\n"
"تبدیلی کی گئی ہے۔ خاص طور پر درج ذیل تبدیلیاں کی گئی ہیں:\n"
"\n"
"%(messages)s\n"
"\n"
"اگر یہ تبدیلی آپ نے نہیں کی تو براہِ کرم فوراً ہم سے رابطہ کریں۔\n"
"\n"
"یہاں اکاؤنٹ کی ترتیبات کا جائزہ لیں اور تبدیل کریں:\n"
"\n"
"%(url)s\n"
"\n"
"نیک تمنائیں،\n"
"آپ کی سسٹم ٹیم\n"

