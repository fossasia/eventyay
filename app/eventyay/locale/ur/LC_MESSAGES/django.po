#: control/templates/pretixcontrol/order/refund_start.html:12
#: control/templates/pretixcontrol/order/sendmail.html:10
#, python-format
msgid "Back to order %(order)s"
msgstr "آرڈر %(order)s پر واپس جائیں"

#: control/templates/pretixcontrol/order/change.html:24
msgid ""
"You can use this tool to change the ordered products or to partially cancel "
"the order. Please keep in mind that changing an order can have several "
"implications, e.g. the payment method fee might change or additional "
"questions can be added to the order that need to be answered by the user."
msgstr ""
"آرڈر کردہ مصنوعات تبدیل کرنے یا آرڈر کو جزوی طور پر منسوخ کرنے کے لیے یہ ٹول "
"استعمال کیا جا سکتا ہے۔ براہِ کرم ذہن میں رکھیں کہ آرڈر تبدیل کرنے کے کئی "
"اثرات ہو سکتے ہیں، مثلاً ادائیگی کے طریقے کی فیس بدل سکتی ہے یا آرڈر میں "
"اضافی سوالات شامل کیے جا سکتے ہیں جن کے جوابات صارف کو دینے ہوں گے۔"

#: control/templates/pretixcontrol/order/change.html:31
msgid ""
"The user will receive a notification about the change but in the case of new "
"required questions, the user will not be forced to answer them."
msgstr ""
"صارف کو تبدیلی کے بارے میں اطلاع موصول ہوگی، لیکن نئے لازمی سوالات کی صورت "
"میں صارف کو ان کے جواب دینے پر مجبور نہیں کیا جائے گا۔"

#: control/templates/pretixcontrol/order/change.html:37
msgid ""
"If an invoice is attached to the order, a cancellation will be created "
"together with a new invoice."
msgstr ""
"اگر آرڈر کے ساتھ کوئی انوائس منسلک ہے تو منسوخی کے ساتھ ایک نیا انوائس بھی "
"بنایا جائے گا۔"

#: control/templates/pretixcontrol/order/change.html:42
msgid ""
"If you chose \"split into new order\" for multiple positions, they will be "
"all split in one second order together, not multiple orders."
msgstr ""
"اگر متعدد پوزیشنز کے لیے \"split into new order\" منتخب کیا گیا ہے تو وہ سب "
"مل کر ایک دوسرے آرڈر میں تقسیم ہوں گی، متعدد آرڈرز میں نہیں۔"

#: control/templates/pretixcontrol/order/change.html:48
msgid ""
"Please use this tool carefully. Changes you make here are not reversible. "
"Also, if you change an order manually, not all constraints (e.g. on required "
"add-ons) will be checked. Therefore, you might construct an order that would "
"not be able to exist otherwise. In most cases it is easier to cancel the "
"order completely and create a new one."
msgstr ""
"براہِ کرم اس ٹول کو احتیاط سے استعمال کریں۔ یہاں کی گئی تبدیلیاں واپس نہیں کی "
"جا سکتیں۔ نیز، اگر آرڈر کو دستی طور پر تبدیل کیا جائے تو تمام پابندیوں (مثلاً "
"لازمی ایڈ آنز سے متعلق) کی جانچ نہیں ہوگی۔ لہٰذا ایسا آرڈر بنایا جا سکتا ہے "
"جو بصورتِ دیگر ممکن نہ ہو۔ زیادہ تر صورتوں میں پورا آرڈر منسوخ کر کے نیا آرڈر "
"بنانا زیادہ آسان ہوتا ہے۔"

#: control/templates/pretixcontrol/order/change.html:68
#, python-format
msgid "Add-On to position #%(posid)s"
msgstr "پوزیشن #%(posid)s کے لیے ایڈ آن"

#: control/templates/pretixcontrol/order/change.html:85
msgid ""
"This position has been created with a voucher with a limited budget. If you "
"change the price or item, the discount will still be calculated from the "
"original price at the time of purchase."
msgstr ""
"یہ پوزیشن محدود بجٹ والے واؤچر کے ساتھ بنائی گئی ہے۔ اگر قیمت یا آئٹم تبدیل "
"کیا جائے تو رعایت پھر بھی خریداری کے وقت کی اصل قیمت کی بنیاد پر ہی حساب کی "
"جائے گی۔"

#: control/templates/pretixcontrol/order/change.html:97
#: control/templates/pretixcontrol/order/change.html:302
msgid "Change to"
msgstr "اس میں تبدیل کریں"

#: control/templates/pretixcontrol/order/change.html:171
#: control/templates/pretixcontrol/order/change.html:321
msgid "including all taxes"
msgstr "تمام ٹیکسوں سمیت"

#: control/templates/pretixcontrol/order/change.html:191
msgid "Removing this position will also remove all add-ons to this position."
msgstr "اس پوزیشن کو ہٹانے سے اس پوزیشن کے تمام ایڈ آنز بھی ہٹا دیے جائیں گے۔"

#: control/templates/pretixcontrol/order/change.html:212
#: control/templates/pretixcontrol/order/change.html:250
#: control/templates/pretixcontrol/order/change.html:275
msgid "Add product"
msgstr "مصنوعات شامل کریں"

#: control/templates/pretixcontrol/order/change.html:329
msgid ""
"Manually modifying payment fees is discouraged since they might "
"automatically be on subsequent order changes or when choosing a different "
"payment method."
msgstr ""
"ادائیگی کی فیس کو دستی طور پر تبدیل کرنے کی حوصلہ افزائی نہیں کی جاتی، "
"کیونکہ وہ بعد کی آرڈر تبدیلیوں پر یا مختلف ادائیگی کا طریقہ منتخب کرنے پر "
"خودکار طور پر سیٹ ہو سکتی ہیں۔"

#: control/templates/pretixcontrol/order/change.html:339
#: control/templates/pretixcontrol/order/change_questions.html:90
msgid "Other operations"
msgstr "دیگر کارروائیاں"

#: control/templates/pretixcontrol/order/change.html:365
msgid "Perform changes"
