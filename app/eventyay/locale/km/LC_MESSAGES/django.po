msgstr "អាចបង្កើតកូដចូលប្រើ <a href=\"{url}\">នៅទីនេះ</a>។"

#: orga/forms/cfp.py:474
msgid "You already have a track by this name!"
msgstr "មានប្រធានបទដែលមានឈ្មោះនេះរួចហើយ!"

#: orga/forms/cfp.py:526
#, python-brace-format
msgid "Access code for the {event} CfP"
msgstr "កូដចូលប្រើសម្រាប់ CfP {event}"

#: orga/forms/cfp.py:530
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"This is an access code for the {event} CfP."
msgstr ""
"សួស្តី!\n"
"\n"
"នេះជាកូដចូលប្រើសម្រាប់ CfP {event}។"

#: orga/forms/cfp.py:540
#, python-brace-format
msgid "It will allow you to submit a proposal to the “{track}” track."
msgstr "វានឹងអនុញ្ញាតឱ្យដាក់សំណើទៅកាន់ប្រធានបទ “ {track} ”។"

#: orga/forms/cfp.py:547
msgid "It will allow you to submit a proposal to our CfP."
msgstr "វានឹងអនុញ្ញាតឱ្យដាក់សំណើទៅកាន់ CfP របស់យើង។"

#: orga/forms/cfp.py:551
#, python-brace-format
msgid "This access code is valid until {date}."
msgstr "កូដចូលប្រើនេះមានសុពលភាពរហូតដល់ {date}។"

#: orga/forms/cfp.py:558
#, python-brace-format
msgid "The code can be redeemed multiple times ({num})."
msgstr "កូដនេះអាចយកទៅប្រើបានច្រើនដង ({num})។"

#: orga/forms/cfp.py:560
#, python-brace-format
msgid ""
"\n"
"Please follow this URL to use the code:\n"
"\n"
"  {url}\n"
"\n"
"I’m looking forward to your proposal!\n"
"{name}"
msgstr ""
"\n"
"សូមទៅតាម URL នេះដើម្បីប្រើកូដ៖\n"
"\n"
"  {url}\n"
"\n"
"ទន្ទឹងរង់ចាំសំណើរបស់អ្នក!\n"
"{name}"

#: orga/forms/cfp.py:591
msgid "Accepted or confirmed speakers"
msgstr "អ្នកនិយាយដែលត្រូវបានទទួលយក ឬបានបញ្ជាក់"

#: orga/forms/cfp.py:592
msgid "Confirmed speakers"
msgstr "អ្នកនិយាយដែលបានបញ្ជាក់"

#: orga/forms/cfp.py:651
msgid "If you select no custom field, all will be used."
msgstr "ប្រសិនបើមិនជ្រើសវាលផ្ទាល់ខ្លួនទេ វាលទាំងអស់នឹងត្រូវបានប្រើ។"

#: orga/forms/event.py:36
msgid "Grid"
msgstr "ក្រឡាចត្រង្គ"

#: orga/forms/event.py:46
msgid "You can type in your CSS instead of uploading it, too."
msgstr "អាចវាយបញ្ចូល CSS ដោយផ្ទាល់ ជំនួសការផ្ទុកឡើងផងដែរ។"

#: orga/forms/event.py:56
msgid "Show schedule publicly"
msgstr "បង្ហាញកាលវិភាគជាសាធារណៈ"

#: orga/forms/event.py:57
msgid ""
"Unset to hide your schedule, e.g. if you want to use the HTML export "
"exclusively."
msgstr ""
"ដោះការកំណត់ ដើម្បីលាក់កាលវិភាគ ឧ. ប្រសិនបើចង់ប្រើតែការនាំចេញ HTML ប៉ុណ្ណោះ។"

#: orga/forms/event.py:66
msgid "Show featured sessions"
msgstr "បង្ហាញសម័យពិសេស"

#: orga/forms/event.py:69
msgid "Until the first schedule is released"
msgstr "រហូតដល់កាលវិភាគដំបូងត្រូវបានចេញផ្សាយ"

#: orga/forms/event.py:73
msgid ""
"Marking sessions as “featured” is a good way to show them before the first "
"schedule release, or to highlight them once the schedule is visible."
msgstr ""
"ការសម្គាល់សម័យថា “ពិសេស” ជាវិធីល្អដើម្បីបង្ហាញវាមុនពេលចេញផ្សាយកាលវិភាគដំបូង ឬដើម្បីរំលេចវា ពេល"
"កាលវិភាគអាចមើលឃើញបាន។"

#: orga/forms/event.py:78
msgid "Enable anonymous feedback"
msgstr "បើកមតិយោបល់អនាមិក"

#: orga/forms/event.py:79
msgid "Attendees will be able to send in feedback after a session is over."
msgstr "អ្នកចូលរួមនឹងអាចផ្ញើមតិយោបល់បាន បន្ទាប់ពីសម័យបានបញ្ចប់។"

#: orga/forms/event.py:83
msgid "Generate HTML export on schedule release"
msgstr "បង្កើតការនាំចេញ HTML នៅពេលចេញផ្សាយកាលវិភាគ"

#: orga/forms/event.py:84
msgid ""
"The static HTML export will be provided as a .zip archive on the schedule "
"export page."
msgstr ""
"ការនាំចេញ HTML ស្ថិតិចនឹងត្រូវបានផ្តល់ជា​បណ្ណសារ .zip នៅលើទំព័រនាំចេញកាលវិភាគ។"

#: orga/forms/event.py:88
msgid "HTML Export URL"
msgstr "URL នាំចេញ HTML"

#: orga/forms/event.py:90
msgid ""
"If you publish your schedule via the HTML export, you will want the correct "
"absolute URL to be set in various places. Please only set this value once "
"you have published your schedule. Should end with a slash."
msgstr ""
"ប្រសិនបើបោះពុម្ពផ្សាយកាលវិភាគតាមរយៈការនាំចេញ HTML នោះនឹងត្រូវការកំណត់ URL ដាច់ខាតត្រឹមត្រូវនៅក"
"ន្លែងផ្សេងៗ។ សូមកំណត់តម្លៃនេះតែបន្ទាប់ពីបានបោះពុម្ពផ្សាយកាលវិភាគរួច។ គួរបញ្ចប់ដោយសញ្ញា / ។"

#: orga/forms/event.py:102
msgid "Ask search engines not to index the event pages"
msgstr "ស្នើឲ្យម៉ាស៊ីនស្វែងរកកុំធ្វើលិបិក្រមទំព័រព្រឹត្តិការណ៍"

#: orga/forms/event.py:111
#, python-brace-format
msgid "You can find the page <a {href}>here</a>."
msgstr "អ្នកអាចរកឃើញទំព័រ <a {href}>នៅទីនេះ</a>។"

#: orga/forms/event.py:173
msgid ""
"Reply-To address. If this setting is empty and you have no custom sender, "
"your event email address will be used as Reply-To address."
msgstr ""
"អាសយដ្ឋាន Reply-To។ ប្រសិនបើការកំណត់នេះទទេ ហើយមិនមានអ្នកផ្ញើផ្ទាល់ខ្លួន អាសយដ្ឋានអ៊ីមែលព្រឹត្តិ"
"ការណ៍របស់អ្នកនឹងត្រូវបានប្រើជា​អាសយដ្ឋាន Reply-To។"

#: orga/forms/event.py:178
msgid "Mail subject prefix"
msgstr "បុព្វបទប្រធានបទអ៊ីមែល"

#: orga/forms/event.py:179
msgid "The prefix will be prepended to outgoing mail subjects in [brackets]."
msgstr "បុព្វបទនឹងត្រូវបានបន្ថែមនៅខាងមុខប្រធានបទអ៊ីមែលចេញ នៅក្នុង [brackets]។"

#: orga/forms/event.py:183
msgid "Mail signature"
msgstr "ហត្ថលេខាអ៊ីមែល"

#: orga/forms/event.py:184
msgid "The signature will be added to outgoing mails, preceded by “-- ”."
msgstr "ហត្ថលេខានឹងត្រូវបានបន្ថែមទៅអ៊ីមែលចេញ ដោយមាន “-- ” នៅខាងមុខ។"

#: orga/forms/event.py:191
msgid "Use custom SMTP server"
msgstr "ប្រើម៉ាស៊ីនមេ SMTP ផ្ទាល់ខ្លួន"

#: orga/forms/event.py:192
msgid ""
"All mail related to your event will be sent over the SMTP server specified "
"by you."
msgstr ""
"អ៊ីមែលទាំងអស់ដែលទាក់ទងនឹងព្រឹត្តិការណ៍របស់អ្នក នឹងត្រូវបានផ្ញើតាមរយៈម៉ាស៊ីនមេ SMTP ដែលអ្នកបានកំណត់។"

#: orga/forms/event.py:197
msgid "Sender address for outgoing emails."
msgstr "អាសយដ្ឋានអ្នកផ្ញើសម្រាប់អ៊ីមែលចេញ។"

#: orga/forms/event.py:215
#, python-brace-format
msgid ""
"The password contains unsupported letters. Please only use characters A-Z, a-"
"z, 0-9, and common special characters ({characters})."
msgstr ""
"ពាក្យសម្ងាត់មានអក្សរដែលមិនគាំទ្រ។ សូមប្រើតែតួអក្សរ A-Z, a-z, 0-9 និងតួអក្សរពិសេសទូទៅ ("
"{characters}) ប៉ុណ្ណោះ។"

#: orga/forms/event.py:253
msgid "You have to provide a sender address if you use a custom SMTP server."
msgstr "ត្រូវផ្តល់អាសយដ្ឋានអ្នកផ្ញើ ប្រសិនបើប្រើម៉ាស៊ីនមេ SMTP ផ្ទាល់ខ្លួន។"

#: orga/forms/event.py:273
msgid ""
"You have to activate either SSL or STARTTLS security if you use a non-local "
"mailserver due to data protection reasons. Your administrator can add an "
"instance-wide bypass. If you use this bypass, please also adjust your "
"Privacy Policy."
msgstr ""
"ត្រូវបើកសុវត្ថិភាព SSL ឬ STARTTLS មួយក្នុងចំណោមទាំងពីរ ប្រសិនបើប្រើម៉ាស៊ីនមែរអ៊ីមែលមិនមែនក្នុងម៉ាស៊ីន"
"មេស្រុក ដោយសារហេតុផលការពារទិន្នន័យ។ អ្នកគ្រប់គ្រងអាចបន្ថែមការលើកលែងសម្រាប់ទាំងអាំងស្តង់ស។ ប្រសិន"
"បើប្រើការលើកលែងនេះ សូមកែសម្រួលគោលនយោបាយឯកជនភាពផងដែរ។"

#: orga/forms/event.py:304
msgid "Enable submission comments"
msgstr "បើកមតិយោបល់លើការដាក់ស្នើ"

#: orga/forms/event.py:305
msgid ""
"Allow organizers and reviewers to comment on submissions, separate from "
"reviews."
msgstr ""
"អនុញ្ញាតឱ្យអ្នករៀបចំ និងអ្នកពិនិត្យ បន្ថែមមតិយោបល់លើការដាក់ស្នើ ដោយឡែកពីការវាយតម្លៃ។"

#: orga/forms/event.py:308
msgid "Require a review score"
msgstr "ទាមទារពិន្ទុវាយតម្លៃ"

#: orga/forms/event.py:309
msgid "Require a review text"
msgstr "ទាមទារអត្ថបទវាយតម្លៃ"

#: orga/forms/event.py:311
msgid "Score display"
msgstr "ការបង្ហាញពិន្ទុ"

#: orga/forms/event.py:314
msgid "Text and score, e.g “Good (3)”"
msgstr "អត្ថបទ និងពិន្ទុ ឧ. “ល្អ (3)”"

#: orga/forms/event.py:315
msgid "Score and text, e.g “3 (good)”"
msgstr "ពិន្ទុ និងអត្ថបទ ឧ. “3 (ល្អ)”"

#: orga/forms/event.py:316
msgid "Just scores"
msgstr "តែពិន្ទុប៉ុណ្ណោះ"

#: orga/forms/event.py:317
msgid "Just text"
msgstr "អក្សរធម្មតា"

#: orga/forms/event.py:321
msgid ""
"This is how the score will look like on the review interface. The dashboard "
"will always show numerical scores."
msgstr ""
"នេះជារបៀបដែលពិន្ទុនឹងបង្ហាញនៅលើចំណុចប្រទាក់ពិនិត្យឡើងវិញ។ ផ្ទាំងគ្រប់គ្រងនឹងបង្ហាញពិន្ទុជាលេខជានិច្ច។"

#: orga/forms/event.py:326
msgid "Score aggregation method"
msgstr "វិធីសាស្ត្រប្រមូលពិន្ទុ"

#: orga/forms/event.py:328 orga/templates/orga/review/dashboard.html:165
msgid "Median"
msgstr "មេដ្យាន"

#: orga/forms/event.py:328
msgid "Average (mean)"
msgstr "មធ្យមភាគ (mean)"

#: orga/forms/event.py:332
msgid "Help text for reviewers"
msgstr "អត្ថបទជំនួយសម្រាប់អ្នកវាយតម្លៃ"

#: orga/forms/event.py:333
msgid ""
"This text will be shown at the top of every review, as long as reviews can "
"be created or edited."
msgstr ""
"អត្ថបទនេះនឹងបង្ហាញនៅខាងលើនៃការវាយតម្លៃទាំងអស់ ដ zolang ដែលអាចបង្កើត ឬកែសម្រួលការវាយតម្"
"លៃបាន។"

#: orga/forms/event.py:353
msgid "Show the widget even if the schedule is not public"
msgstr "បង្ហាញវីដហ្សិត ទោះបីកាលវិភាគមិនសាធារណៈក៏ដោយ"

#: orga/forms/event.py:355
msgid ""
"Set to allow external pages to show the schedule widget, even if the "
"schedule is not shown here using eventyay."
msgstr ""
"កំណត់ដើម្បីអនុញ្ញាតឱ្យទំព័រខាងក្រៅបង្ហាញវីដហ្សិតកាលវិភាគ ទោះបីកាលវិភាគមិនត្រូវបានបង្ហាញនៅទីនេះដោយប្"
"រើ eventyay ក៏ដោយ។"

#: orga/forms/event.py:371
msgid "Limit days"
msgstr "កំណត់ចំនួនថ្ងៃ"

#: orga/forms/event.py:375
msgid ""
"You can limit the days shown in the widget. Leave empty to show all days."
msgstr ""
"អាចកំណត់ចំនួនថ្ងៃដែលបង្ហាញក្នុងវីដហ្សិតបាន។ ទុកឲ្យទទេ ដើម្បីបង្ហាញថ្ងៃទាំងអស់។"

#: orga/forms/event.py:380
msgid "Widget language"
msgstr "ភាសាវីដហ្សិត"

#: orga/forms/event.py:405
msgid "The end of a phase has to be after its start."
msgstr "ចុងបញ្ចប់នៃដំណាក់កាលត្រូវតែនៅក្រោយការចាប់ផ្តើមរបស់វា។"

#: orga/forms/export.py:18
msgid "A CSV export can be opened directly in Excel and similar applications."
msgstr "ការនាំចេញ CSV អាចបើកដោយផ្ទាល់ក្នុង Excel និងកម្មវិធីស្រដៀងគ្នា។"

#: orga/forms/export.py:20
msgid "CSV export"
msgstr "នាំចេញ CSV"

#: orga/forms/export.py:21
