msgstr ""
"បានទទួលសំណើរបស់អ្នកសម្រាប់ការលុបចោលការបញ្ជាទិញនេះ។ សូមអត់ធ្មត់ ខណៈដែលអ្នករៀបចំព្រឹត្តិការណ៍សម្រេចចិ"
"ត្តលើការលុបចោល។"

#: presale/templates/pretixpresale/event/order.html:136
#, python-format
msgid "A refund of %(amount)s will be sent out to you soon, please be patient."
msgstr ""
"ការបង្វិលប្រាក់ចំនួន %(amount)s នឹងត្រូវផ្ញើជូនក្នុងពេលឆាប់ៗនេះ សូមអត់ធ្មត់។"

#: presale/templates/pretixpresale/event/order.html:143
