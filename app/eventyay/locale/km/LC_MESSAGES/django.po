#: control/templates/pretixcontrol/items/question_edit.html:133
msgid "Custom field dependency"
msgstr "ភាពអាស្រ័យរបស់វាលផ្ទាល់ខ្លួន"

#: control/templates/pretixcontrol/items/questions.html:4
#: control/templates/pretixcontrol/items/questions.html:9
msgid "Custom Fields"
msgstr "វាលផ្ទាល់ខ្លួន"

#: control/templates/pretixcontrol/items/questions.html:15
msgid ""
"Custom Fields allow your attendees to fill in additional data about their "
"ticket. If you provide food, one example might be to ask your users about "
"dietary requirements."
msgstr ""
"វាលផ្ទាល់ខ្លួនអនុញ្ញាតឱ្យអ្នកចូលរួមបំពេញទិន្នន័យបន្ថែមអំពីសំបុត្ររបស់ពួកគេ។ ប្រសិនបើមានការផ្តល់អាហារ ឧ"
"ទាហរណ៍មួយអាចជាសួរអ្នកប្រើអំពីតម្រូវការរបបអាហារ។"

#: control/templates/pretixcontrol/items/questions.html:64
msgid "System custom field"
msgstr "វាលផ្ទាល់ខ្លួនរបស់ប្រព័ន្ធ"

#: control/templates/pretixcontrol/items/questions.html:69
msgid "Required custom field"
msgstr "វាលផ្ទាល់ខ្លួនដែលត្រូវការ"

#: control/templates/pretixcontrol/items/questions.html:74
msgid "Ask during check-in"
msgstr "សួរពេលចុះឈ្មោះចូល"

#: control/templates/pretixcontrol/items/questions.html:80
msgid "Hidden custom field"
msgstr "វាលផ្ទាល់ខ្លួនដែលលាក់"

#: control/templates/pretixcontrol/items/questions.html:93
msgid "All admission products"
msgstr "ផលិតផលចូលរួមទាំងអស់"

#: control/templates/pretixcontrol/items/quota.html:6
#: control/templates/pretixcontrol/items/quota.html:12
#: control/templates/pretixcontrol/items/quota_edit.html:6
