#: base/services/mail.py:217
#, python-brace-format
msgid ""
"You are receiving this email because someone placed an order for {event} for "
"you."
msgstr ""
"កំពុងទទួលបានអ៊ីមែលនេះ ពីព្រោះមាននរណាម្នាក់បានដាក់ការបញ្ជាទិញ {event} សម្រាប់។"

#: base/services/mail.py:221 base/services/mail.py:242
#, python-brace-format
msgid ""
"You can view your order details at the following URL:\n"
"{orderurl}."
msgstr ""
"អាចមើលព័ត៌មានលម្អិតការបញ្ជាទិញបានតាម URL ខាងក្រោម៖\n"
"{orderurl}។"

#: base/services/mail.py:237
#, python-brace-format
msgid "You are receiving this email because you placed an order for {event}."
msgstr "កំពុងទទួលបានអ៊ីមែលនេះ ពីព្រោះបានដាក់ការបញ្ជាទិញ {event}។"

#: base/services/orderimport.py:91
#, python-brace-format
msgid ""
"Error while importing value \"{value}\" for column \"{column}\" in line "
"\"{line}\": {message}"
msgstr ""
"កំហុសនៅពេលនាំចូលតម្លៃ \"{value}\" សម្រាប់ជួរឈរ \"{column}\" នៅក្នុងជួរ \"{line}\": "
"{message}"

#: base/services/orderimport.py:126
#, python-brace-format
msgid "Invalid data in row {row}: {message}"
msgstr "ទិន្នន័យមិនត្រឹមត្រូវនៅក្នុងជួរ {row}៖ {message}"

#: base/services/orders.py:98
msgid ""
"Some of the products you selected were no longer available. Please see below "
"for details."
msgstr "ផលិតផលមួយចំនួនដែលបានជ្រើសរើស មិនមានទៀតទេ។ សូមមើលព័ត៌មានលម្អិតខាងក្រោម។"

#: base/services/orders.py:100
msgid ""
"Some of the products you selected were no longer available in the quantity "
"you selected. Please see below for details."
msgstr ""
"ផលិតផលមួយចំនួនដែលបានជ្រើសរើស មិនមានក្នុងបរិមាណដែលបានជ្រើសរើសទៀតទេ។ សូមមើលព័ត៌មានលម្អិតខាងក្រោ"
"ម។"

#: base/services/orders.py:104
msgid ""
"The price of some of the products in your cart has changed in the meantime. "
"Please see below for details."
msgstr ""
"តម្លៃផលិតផលមួយចំនួនក្នុងកន្ត្រកបានផ្លាស់ប្តូរនៅពេលនេះ។ សូមមើលព័ត៌មានលម្អិតខាងក្រោម។"

#: base/services/orders.py:106
msgid "An internal error occurred, please try again."
msgstr "មានកំហុសខាងក្នុងកើតឡើង សូមព្យាយាមម្តងទៀត។"

#: base/services/orders.py:107
msgid "Your cart is empty."
msgstr "កន្ត្រកទំនិញទទេ។"

#: base/services/orders.py:109
#, python-format
msgid ""
"You cannot select more than %(max)s products of the product %(product)s. We "
"removed the surplus products from your cart."
msgstr ""
"មិនអាចជ្រើសរើសផលិតផល %(product)s លើសពី %(max)s បានទេ។ បានដកផលិតផលលើសចេញពីកន្ត្រក។"

#: base/services/orders.py:114
msgid "The presale period has ended."
msgstr "រយៈពេលលក់ជាមុនបានបញ្ចប់។"

#: base/services/orders.py:115
msgid ""
"The voucher code used for one of the products in your cart is not known in "
"our database."
msgstr ""
"កូដប័ណ្ណបញ្ចុះតម្លៃដែលបានប្រើសម្រាប់ផលិតផលមួយក្នុងកន្ត្រក មិនត្រូវបានស្គាល់ក្នុងមូលដ្ឋានទិន្នន័យ។"

#: base/services/orders.py:117
msgid ""
"The voucher code used for one of the products in your cart has already been "
"used the maximum number of times allowed. We removed this product from your "
"cart."
msgstr ""
"កូដប័ណ្ណបញ្ចុះតម្លៃដែលបានប្រើសម្រាប់ផលិតផលមួយក្នុងកន្ត្រក ត្រូវបានប្រើរួចហើយដល់ចំនួនអតិបរមាដែលអនុញ្ញាត"
"។ បានដកផលិតផលនេះចេញពីកន្ត្រក។"

#: base/services/orders.py:121
msgid ""
"The voucher code used for one of the products in your cart has already been "
"too often. We adjusted the price of the product in your cart."
msgstr ""
"កូដប័ណ្ណបញ្ចុះតម្លៃដែលបានប្រើសម្រាប់ផលិតផលមួយក្នុងកន្ត្រក ត្រូវបានប្រើញឹកញាប់ពេក។ បានកែសម្រួលតម្លៃផលិ"
"តផលក្នុងកន្ត្រក។"

#: base/services/orders.py:125
msgid ""
"The voucher code used for one of the products in your cart is expired. We "
"removed this product from your cart."
msgstr ""
"កូដប័ណ្ណបញ្ចុះតម្លៃដែលបានប្រើសម្រាប់ផលិតផលមួយក្នុងរទេះទំនិញបានផុតកំណត់។ បានលុបផលិតផលនេះចេញពីរទេះទំនិ"
"ញ។"

#: base/services/orders.py:128
msgid ""
"The voucher code used for one of the products in your cart is not valid for "
"this product. We removed this product from your cart."
msgstr ""
"កូដប័ណ្ណបញ្ចុះតម្លៃដែលបានប្រើសម្រាប់ផលិតផលមួយក្នុងរទេះទំនិញមិនមានសុពលភាពសម្រាប់ផលិតផលនេះទេ។ បានលុប"
"ផលិតផលនេះចេញពីរទេះទំនិញ។"

#: base/services/orders.py:132
msgid ""
"You need a valid voucher code to order one of the products in your cart. We "
"removed this product from your cart."
msgstr ""
"ត្រូវការកូដប័ណ្ណបញ្ចុះតម្លៃដែលមានសុពលភាព ដើម្បីបញ្ជាទិញផលិតផលមួយក្នុងរទេះទំនិញ។ បានលុបផលិតផលនេះចេញ"
"ពីរទេះទំនិញ។"

#: base/services/orders.py:135
msgid ""
"The presale period for one of the events in your cart has not yet started. "
"The affected positions have been removed from your cart."
msgstr ""
"រយៈពេលលក់ជាមុនសម្រាប់ព្រឹត្តិការណ៍មួយក្នុងរទេះទំនិញមិនទាន់ចាប់ផ្តើមទេ។ បានលុបមុខទំនិញដែលពាក់ព័ន្ធចេញពីរ"
"ទេះទំនិញ។"

#: base/services/orders.py:142
msgid ""
"One of the seats in your order was invalid, we removed the position from "
"your cart."
msgstr "កៅអីមួយក្នុងការបញ្ជាទិញមិនត្រឹមត្រូវទេ បានលុបមុខទំនិញចេញពីរទេះទំនិញ។"

#: base/services/orders.py:144
msgid ""
"One of the seats in your order has been taken in the meantime, we removed "
"the position from your cart."
msgstr ""
"កៅអីមួយក្នុងការបញ្ជាទិញត្រូវបានយកទៅរួចហើយក្នុងអំឡុងពេលនេះ បានលុបមុខទំនិញចេញពីរទេះទំនិញ។"

#: base/services/orders.py:217 control/forms/orders.py:80
msgid "The new expiry date needs to be in the future."
msgstr "កាលបរិច្ឆេទផុតកំណត់ថ្មីត្រូវតែនៅពេលអនាគត។"

#: base/services/orders.py:298 base/services/orders.py:371
msgid "This order is not pending approval."
