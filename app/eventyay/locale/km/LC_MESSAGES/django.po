#: presale/templates/pretixpresale/event/order.html:98
msgid "Re-try payment or choose another payment method"
msgstr "ព្យាយាមទូទាត់ម្ដងទៀត ឬជ្រើសរើសវិធីទូទាត់ផ្សេង"

