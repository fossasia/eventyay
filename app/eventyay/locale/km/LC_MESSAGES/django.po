#: event/forms.py:105
msgid "Enter one email address per line."
msgstr "បញ្ចូលអាសយដ្ឋានអ៊ីមែលមួយក្នុងមួយបន្ទាត់។"

#: event/forms.py:124
#, python-format
msgid "“%(email)s” is not a valid email address."
msgstr "“%(email)s” មិនមែនជាអាសយដ្ឋានអ៊ីមែលត្រឹមត្រូវទេ។"

#: event/forms.py:134
msgid "Please enter at least one email address!"
msgstr "សូមបញ្ចូលអាសយដ្ឋានអ៊ីមែលយ៉ាងហោចណាស់មួយ!"

#: event/forms.py:208
msgid ""
"This is the address your event will be available at. Should be short, only "
"contain lowercase letters and numbers, and must be unique. We recommend some "
"kind of abbreviation with less than 30 characters that can be easily "
"remembered."
msgstr ""
"នេះជាអាសយដ្ឋានដែលព្រឹត្តិការណ៍នឹងមាននៅ។ គួរតែខ្លី មានតែអក្សរតូច និងលេខប៉ុណ្ណោះ ហើយត្រូវតែមានតែមួ"
"យគត់។ ណែនាំឱ្យប្រើអក្សរកាត់ប្រហែលមួយដែលមានតួអក្សរតិចជាង 30 ហើយងាយចងចាំ។"

#: event/forms.py:214
msgid "You cannot change the slug later on!"
msgstr "មិនអាចផ្លាស់ប្តូរ slug នៅពេលក្រោយបានទេ!"

#: event/forms.py:224
msgid ""
"This short name is already taken, please choose another one (or ask the "
"owner of that event to add you to their team)."
msgstr ""
"ឈ្មោះខ្លីនេះត្រូវបានយករួចហើយ សូមជ្រើសរើសឈ្មោះផ្សេងទៀត (ឬស្នើឱ្យម្ចាស់ព្រឹត្តិការណ៍នោះបន្ថែមទៅក្រុមរ"
"បស់ពួកគេ)។"

#: event/forms.py:320
msgid ""
"You can copy settings from previous events here, such as mail settings, "
"session types, and email templates. Please check those settings once the "
"event has been created!"
msgstr ""
"អាចចម្លងការកំណត់ពីព្រឹត្តិការណ៍មុនៗនៅទីនេះ ដូចជា ការកំណត់អ៊ីមែល ប្រភេទសម័យ និងពុម្ពអ៊ីមែល។ សូមពិនិត្យការ"
"កំណត់ទាំងនោះម្តងទៀត បន្ទាប់ពីបានបង្កើតព្រឹត្តិការណ៍រួច!"

#: event/stages.py:41
msgid "Preparation"
msgstr "ការរៀបចំ"

#: event/stages.py:45
msgid "Configure the event"
msgstr "កំណត់រចនាសម្ព័ន្ធព្រឹត្តិការណ៍"

#: event/stages.py:46
msgid "Gather your team"
msgstr "ប្រមូលក្រុម"

#: event/stages.py:47
msgid "Write a CfP"
msgstr "សរសេរ CfP"

#: event/stages.py:49
msgid "Customize mail templates"
msgstr "កែតម្រូវពុម្ពអ៊ីមែល"

#: event/stages.py:55
msgid "CfP is open"
msgstr "CfP បើក"

#: event/stages.py:59
msgid "Monitor proposals"
msgstr "តាមដានសំណើ"

#: event/stages.py:61
msgid "Submit sessions for your speakers"
msgstr "ដាក់ស្នើសម័យសម្រាប់អ្នកនិយាយ"

#: event/stages.py:64
msgid "Invite reviewers"
msgstr "អញ្ជើញអ្នកពិនិត្យ"

#: event/stages.py:72
msgid "Let reviewers do their work"
msgstr "ឱ្យអ្នកពិនិត្យធ្វើការងាររបស់ពួកគេ"

#: event/stages.py:74
msgid "Accept or reject proposals"
msgstr "ទទួលយក ឬបដិសេធសំណើ"

#: event/stages.py:77
msgid "Build your first schedule"
msgstr "បង្កើតកាលវិភាគដំបូង"

#: event/stages.py:86
msgid "Release schedules as needed"
msgstr "ចេញផ្សាយកាលវិភាគតាមតម្រូវការ"

#: event/stages.py:90
msgid "Inform your speakers about the infrastructure"
msgstr "ជូនដំណឹងដល់អ្នកនិយាយអំពីហេដ្ឋារចនាសម្ព័ន្ធ"

#: event/stages.py:100
msgid "Provide a point of contact for the speakers"
msgstr "ផ្តល់អ្នកទំនាក់ទំនងសម្រាប់អ្នកនិយាយ"

#: event/stages.py:101
msgid "Enjoy the event!"
msgstr "រីករាយនឹងព្រឹត្តិការណ៍!"

#: event/stages.py:105
msgid "Wrapup"
msgstr "បញ្ចប់"

#: event/stages.py:109
msgid "Monitor incoming feedback"
msgstr "ត្រួតពិនិត្យ​មតិយោបល់​ចូល​មក"

#: event/stages.py:110
msgid "Embed session recordings if available"
msgstr "បង្កប់​កំណត់ត្រា​សម័យ ប្រសិនបើ​មាន"

#: event/stages.py:111
msgid "Release next event date?"
msgstr "ប្រកាស​កាលបរិច្ឆេទ​ព្រឹត្តិការណ៍​បន្ទាប់?"

#: eventyay_common/forms/filters.py:38
msgid "Search by session name"
msgstr "ស្វែងរក​តាម​ឈ្មោះ​សម័យ"

