msgstr "បោះពុម្ព"

#: presale/templates/pretixpresale/event/order.html:145
#, python-format
msgid ""
"We've issued your refund of %(amount)s as a gift card. On your next purchase "
"with us, you can use the following gift card code during payment:"
msgstr ""
"បានចេញការបង្វិលប្រាក់ចំនួន %(amount)s ជាកាតអំណោយ។ នៅពេលទិញលើកក្រោយ អាចប្រើលេខកូដកាតអំណោយ"
