#: control/templates/pretixcontrol/email/forgot.txt:1
#, python-format
msgid ""
"Hello,\n"
"\n"
"you requested a new password. Please go to the following page to reset your "
"password:\n"
"\n"
"%(url)s\n"
"\n"
"Best regards,\n"
"Your system team\n"
msgstr ""
"សួស្តី\n"
"\n"
"បានស្នើសុំពាក្យសម្ងាត់ថ្មី។ សូមទៅកាន់ទំព័រខាងក្រោម ដើម្បីកំណត់ពាក្យសម្ងាត់ឡើងវិញ៖\n"
"\n"
"%(url)s\n"
"\n"
"ដោយក្តីគោរព\n"
"ក្រុមប្រព័ន្ធ\n"

#: control/templates/pretixcontrol/email/invitation.txt:1
#, python-format
msgid ""
"Hello,\n"
"\n"
"You have been added to the following event team:\n"
"\n"
"Organizer: %(organizer)s\n"
"Team: %(team)s\n"
"\n"
"Click the following link to view your team dashboard:\n"
"\n"
"%(url)s\n"
"\n"
"Best regards,\n"
"\n"
"Your event team\n"
msgstr ""
"សួស្តី\n"
"\n"
"ត្រូវបានបន្ថែមទៅកាន់ក្រុមព្រឹត្តិការណ៍ខាងក្រោម៖\n"
"\n"
"អ្នករៀបចំ៖ %(organizer)s\n"
"ក្រុម៖ %(team)s\n"
"\n"
"ចុចតំណភ្ជាប់ខាងក្រោម ដើម្បីមើលផ្ទាំងគ្រប់គ្រងក្រុម៖\n"
"\n"
"%(url)s\n"
"\n"
"ដោយក្តីគោរព\n"
"\n"
"ក្រុមព្រឹត្តិការណ៍\n"

#: control/templates/pretixcontrol/email/invitation.txt:15
#, python-format
msgid ""
"Hello,\n"
"\n"
"You have been invited to the following event team:\n"
"\n"
"Organizer: %(organizer)s\n"
"Team: %(team)s\n"
"\n"
"If you want to join that team, just click on the following link:\n"
"\n"
"%(url)s\n"
"\n"
"If you do not want to join, you can safely ignore or delete this email.\n"
"\n"
"Best regards,\n"
"\n"
"Your event team\n"
msgstr ""
"សួស្តី\n"
"\n"
"ត្រូវបានអញ្ជើញទៅកាន់ក្រុមព្រឹត្តិការណ៍ខាងក្រោម៖\n"
"\n"
"អ្នករៀបចំ៖ %(organizer)s\n"
"ក្រុម៖ %(team)s\n"
"\n"
"បើចង់ចូលរួមក្រុមនោះ គ្រាន់តែចុចតំណភ្ជាប់ខាងក្រោម៖\n"
"\n"
"%(url)s\n"
"\n"
"បើមិនចង់ចូលរួម អាចមិនអើពើ ឬលុបអ៊ីមែលនេះបានដោយសុវត្ថិភាព។\n"
"\n"
"ដោយក្តីគោរព\n"
"\n"
"ក្រុមព្រឹត្តិការណ៍\n"

#: control/templates/pretixcontrol/email/security_notice.txt:1
#, python-format
msgid ""
"Hello,\n"
"\n"
"this is to inform you that the account information of your eventyay account "
"has been\n"
"changed. In particular, the following changes have been performed:\n"
"\n"
"%(messages)s\n"
"\n"
"If this change was not performed by you, please contact us immediately.\n"
"\n"
"You can review and change your account settings here:\n"
"\n"
"%(url)s\n"
"\n"
"Best regards,\n"
"Your system team\n"
msgstr ""
"សួស្តី\n"
"\n"
"សូមជូនដំណឹងថា ព័ត៌មានគណនី eventyay ត្រូវបាន\n"
"ផ្លាស់ប្តូរ។ ជាពិសេស ការផ្លាស់ប្តូរខាងក្រោមត្រូវបានអនុវត្ត៖\n"
"\n"
"%(messages)s\n"
"\n"
"បើការផ្លាស់ប្តូរនេះមិនបានអនុវត្តដោយអ្នក សូមទាក់ទងមកភ្លាមៗ។\n"
"\n"
"អាចពិនិត្យមើល និងផ្លាស់ប្តូរការកំណត់គណនីនៅទីនេះ៖\n"
"\n"
"%(url)s\n"
"\n"
"ដោយក្តីគោរព\n"
"ក្រុមប្រព័ន្ធ\n"

