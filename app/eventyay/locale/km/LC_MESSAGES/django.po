#: base/services/vouchers.py:45 control/logdisplay.py:602
#, python-brace-format
msgid "The voucher has been sent to {recipient}."
msgstr "បានផ្ញើប័ណ្ណបញ្ចុះតម្លៃទៅ {recipient}។"

#: base/settings.py:142 control/forms/event.py:264
msgid ""
"Your default locale must also be enabled for your event (see box above)."
msgstr ""
"មូលដ្ឋានភាសាលំនាំដើមក៏ត្រូវតែបានបើកសម្រាប់ព្រឹត្តិការណ៍ (មើលប្រអប់ខាងលើ)។"

#: base/settings.py:151 control/forms/event.py:131
msgid "Content languages must be a subset of the active languages."
msgstr "ភាសាមាតិកាត្រូវតែជាសំណុំរងនៃភាសាសកម្ម។"

#: base/settings.py:155
msgid ""
"You cannot require specifying attendee names if you do not ask for them."
msgstr "មិនអាចទាមទារការបញ្ជាក់ឈ្មោះអ្នកចូលរួមបានទេ ប្រសិនបើមិនស្នើសុំវា។"

#: base/settings.py:159
msgid "You have to ask for attendee emails if you want to make them required."
msgstr "ត្រូវស្នើសុំអ៊ីមែលអ្នកចូលរួម ប្រសិនបើចង់ឲ្យវាជាកាតព្វកិច្ច។"

#: base/settings.py:163
msgid "You have to ask for order email if you want to make it required."
msgstr "ត្រូវស្នើសុំអ៊ីមែលការបញ្ជាទិញ ប្រសិនបើចង់ឲ្យវាជាកាតព្វកិច្ច។"

#: base/settings.py:167
msgid ""
"You have to ask for invoice addresses if you want to make them required."
msgstr "ត្រូវស្នើសុំអាសយដ្ឋានវិក្កយបត្រ ប្រសិនបើចង់ឲ្យវាជាកាតព្វកិច្ច។"

#: base/settings.py:173
msgid "You have to require invoice addresses to require for company names."
msgstr "ត្រូវទាមទារអាសយដ្ឋានវិក្កយបត្រ ដើម្បីអាចទាមទារឈ្មោះក្រុមហ៊ុន។"

#: base/settings.py:182
msgid "The last payment date cannot be before the end of presale."
msgstr "កាលបរិច្ឆេទបង់ប្រាក់ចុងក្រោយមិនអាចមុនចុងបញ្ចប់នៃការលក់មុនបានទេ។"

#: base/shredder.py:47 base/shredder.py:50
msgid "Your event needs to be over for at least 30 days to use this feature."
msgstr "ព្រឹត្តិការណ៍ត្រូវបានបញ្ចប់យ៉ាងហោចណាស់ 30 ថ្ងៃ ទើបអាចប្រើមុខងារនេះបាន។"

#: base/shredder.py:52
msgid "Your ticket shop needs to be offline to use this feature."
msgstr "ហាងសំបុត្រត្រូវតែអហ្វឡាញ ទើបអាចប្រើមុខងារនេះបាន។"

#: base/shredder.py:142
msgid "Phone numbers"
msgstr "លេខទូរស័ព្ទ"

#: base/shredder.py:144
msgid "This will remove all phone numbers from orders."
msgstr "វានឹងលុបលេខទូរស័ព្ទទាំងអស់ចេញពីការបញ្ជាទិញ។"

#: base/shredder.py:173
msgid "E-mails"
msgstr "អ៊ីមែល"

#: base/shredder.py:176
msgid ""
"This will remove all e-mail addresses from orders and attendees, as well as "
"logged email contents."
msgstr ""
"វានឹងលុបអាសយដ្ឋានអ៊ីមែលទាំងអស់ចេញពីការបញ្ជាទិញ និងអ្នកចូលរួម ព្រមទាំងមាតិកាអ៊ីមែលដែលបានកត់ត្រាទុក។"

#: base/shredder.py:233
msgid ""
"This will remove all names, email addresses, and phone numbers from the "
"waiting list."
msgstr "វានឹងលុបឈ្មោះ អាសយដ្ឋានអ៊ីមែល និងលេខទូរស័ព្ទទាំងអស់ចេញពីបញ្ជីរង់ចាំ។"

#: base/shredder.py:268
msgid "Attendee info"
msgstr "ព័ត៌មានអ្នកចូលរួម"

#: base/shredder.py:271
msgid ""
"This will remove all attendee names and postal addresses from order "
"positions, as well as logged changes to them."
msgstr ""
"វានឹងលុបឈ្មោះអ្នកចូលរួម និងអាសយដ្ឋានប្រៃសណីយ៍ទាំងអស់ចេញពីទីតាំងបញ្ជាទិញ ព្រមទាំងការផ្លាស់ប្តូរដែលបានក"
"ត់ត្រាទុក។"

#: base/shredder.py:338
msgid "Invoice addresses"
msgstr "អាសយដ្ឋានវិក្កយបត្រ"

#: base/shredder.py:341
msgid ""
"This will remove all invoice addresses from orders, as well as logged "
"changes to them."
msgstr ""
"វានឹងលុបអាសយដ្ឋានវិក្កយបត្រទាំងអស់ចេញពីការបញ្ជាទិញ ព្រមទាំងការផ្លាស់ប្តូរដែលបានកត់ត្រាទុក។"

#: base/shredder.py:372
msgid "Question answers"
msgstr "ចម្លើយសំណួរ"

#: base/shredder.py:374
msgid ""
"This will remove all answers to questions, as well as logged changes to them."
msgstr "វានឹងលុបចម្លើយទាំងអស់ចំពោះសំណួរ ព្រមទាំងការផ្លាស់ប្តូរដែលបានកត់ត្រាទុក។"

#: base/shredder.py:411
msgid ""
"This will remove all invoice PDFs, as well as any of their text content that "
"might contain personal data from the database. Invoice numbers and totals "
"will be conserved."
msgstr ""
"វានឹងលុប PDF វិក្កយបត្រទាំងអស់ ព្រមទាំងមាតិកាអត្ថបទណាមួយរបស់វាដែលអាចមានទិន្នន័យផ្ទាល់ខ្លួន ចេញពីមូល"
"ដ្ឋានទិន្នន័យ។ លេខវិក្កយបត្រ និងសរុបនឹងត្រូវរក្សាទុក។"

#: base/shredder.py:439
msgid "Cached ticket files"
msgstr "ឯកសារសំបុត្រដែលបានដាក់ក្នុងឃ្លាំងសម្ងាត់"

#: base/shredder.py:441
msgid "This will remove all cached ticket files. No download will be offered."
msgstr ""
"វានឹងលុបឯកសារសំបុត្រដែលបានដាក់ក្នុងឃ្លាំងសម្ងាត់ទាំងអស់។ នឹងមិនផ្តល់ការទាញយកទេ។"

#: base/shredder.py:457
msgid ""
"This will remove payment-related information. Depending on the payment "
"method, all data will be removed or personal data only. No download will be "
"offered."
msgstr ""
"វានឹងលុបព័ត៌មានពាក់ព័ន្ធនឹងការទូទាត់។ អាស្រ័យលើវិធីទូទាត់ ទិន្នន័យទាំងអស់នឹងត្រូវលុប ឬតែលុបទិន្នន័យផ្ទាល់ខ្លួន"
"ប៉ុណ្ណោះ។ នឹងមិនផ្តល់ការទាញយកទេ។"

#: base/templates/400.html:4 base/templates/400.html:8
msgid "Bad Request"
msgstr "សំណើមិនត្រឹមត្រូវ"

#: base/templates/400.html:9
msgid "We were unable to parse your request."
msgstr "មិនអាចវិភាគសំណើបានទេ។"

