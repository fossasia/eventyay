msgstr "ការពន្យល់អំពីទិន្នន័យអ្នកចូលរួម"

#: base/configurations/default_setting.py:2327
msgid ""
"This text will be shown above the questions asked for every admission "
"product. You can use it e.g. to explain why you need information from them."
msgstr ""
"អត្ថបទនេះនឹងត្រូវបង្ហាញនៅលើសំណួរដែលសួរសម្រាប់ផលិតផលចូលរួមទាំងអស់។ អាចប្រើវាឧ. ដើម្បីពន្យល់មូលហេតុដែ"
"លត្រូវការព័ត៌មានពីពួកគេ។"

#: base/configurations/default_setting.py:2338
msgid "Additional success message"
msgstr "សារជោគជ័យបន្ថែម"

#: base/configurations/default_setting.py:2340
msgid ""
"This message will be shown after an order has been created successfully. It "
"will be shown in additionalto the default text."
msgstr ""
"សារនេះនឹងត្រូវបង្ហាញបន្ទាប់ពីការបញ្ជាទិញត្រូវបានបង្កើតដោយជោគជ័យ។ វានឹងត្រូវបង្ហាញបន្ថែមលើអត្ថបទលំ"
"នាំដើម។"

#: base/configurations/default_setting.py:2354
msgid "Help text of the phone number field"
msgstr "អត្ថបទជំនួយសម្រាប់វាលលេខទូរស័ព្ទ"

#: base/configurations/default_setting.py:2362
msgid ""
"Make sure to enter a valid email address. We will send you an order "
"confirmation including a link that you need to access your order later."
msgstr ""
"សូមប្រាកដថាបញ្ចូលអាសយដ្ឋានអ៊ីមែលត្រឹមត្រូវ។ ការបញ្ជាក់ការបញ្ជាទិញនឹងត្រូវផ្ញើទៅ រួមមានតំណភ្ជាប់ដែលត្រូ"
"វប្រើដើម្បីចូលមើលការបញ្ជាទិញនៅពេលក្រោយ។"

#: base/configurations/default_setting.py:2370
msgid "Help text of the email field"
msgstr "អត្ថបទជំនួយសម្រាប់វាលអ៊ីមែល"

#: base/configurations/default_setting.py:2395
msgid "Allow creating a new team during event creation"
msgstr "អនុញ្ញាតឱ្យបង្កើតក្រុមថ្មីពេលបង្កើតព្រឹត្តិការណ៍"

#: base/configurations/default_setting.py:2397
msgid ""
"Users that do not have access to all events under this organizer, must "
"select one of their teams to have access to the created event. This setting "
"allows users to create an event-specified team on-the-fly, even when they do "
"not have \"Can change teams and permissions\" permission."
msgstr ""
"អ្នកប្រើដែលមិនមានសិទ្ធិចូលដំណើរការព្រឹត្តិការណ៍ទាំងអស់ក្រោមអ្នករៀបចំនេះ ត្រូវជ្រើសរើសក្រុមមួយក្នុងចំណោមក្"
"រុមរបស់ខ្លួន ដើម្បីមានសិទ្ធិចូលដំណើរការព្រឹត្តិការណ៍ដែលបានបង្កើត។ ការកំណត់នេះអនុញ្ញាតឱ្យអ្នកប្រើបង្កើត"
"ក្រុមជាក់លាក់សម្រាប់ព្រឹត្តិការណ៍ភ្លាមៗ ទោះបីពួកគេមិនមានសិទ្ធិ \"Can change teams and "
"permissions\" ក៏ដោយ។"

