#: base/templates/404.html:4 base/templates/404.html:8
msgid "Not found"
msgstr "រកមិនឃើញ"

#: base/templates/404.html:9
msgid "I'm afraid we could not find the the resource you requested."
msgstr "សូមអភ័យទោស មិនអាចរកឃើញធនធានដែលបានស្នើសុំទេ។"

#: base/templates/500.html:4 base/templates/500.html:8
msgid "Internal Server Error"
msgstr "កំហុសម៉ាស៊ីនមេខាងក្នុង"

#: base/templates/500.html:9
msgid "We had trouble processing your request."
msgstr "មានបញ្ហាក្នុងការដំណើរការសំណើ។"

#: base/templates/500.html:10
msgid "If this problem persists, please contact us."
msgstr "បើបញ្ហានេះនៅបន្ត សូមទាក់ទង។"

#: base/templates/500.html:13
msgid "If you contact us, please send us the following code:"
msgstr "បើទាក់ទង សូមផ្ញើកូដខាងក្រោម៖"

#: base/templates/csrffail.html:4 base/templates/csrffail.html:8
msgid "Verification failed"
msgstr "ការផ្ទៀងផ្ទាត់បរាជ័យ"

#: base/templates/csrffail.html:9
msgid ""
"We could not verify that this request really was sent from you. For security "
"reasons, we therefore cannot process it."
msgstr ""
"មិនអាចផ្ទៀងផ្ទាត់ថាសំណើនេះពិតជាត្រូវបានផ្ញើពីលោកអ្នកទេ។ ដោយហេតុផលសុវត្ថិភាព ដូច្នេះមិនអាចដំណើរកា"
"របានទេ។"

#: base/templates/csrffail.html:20
msgid ""
"Please go back to the last page, refresh this page and then try again. If "
"the problem persists, please get in touch with us."
msgstr ""
"សូមត្រឡប់ទៅទំព័រមុន ធ្វើបច្ចុប្បន្នភាពទំព័រនេះ រួចព្យាយាមម្ដងទៀត។ បើបញ្ហានេះនៅបន្ត សូមទាក់ទង។"

#: base/templates/pretixbase/cachedfiles/pending.html:21
msgid "We are preparing your file for download …"
msgstr "កំពុងរៀបចំឯកសារសម្រាប់ទាញយក…"

#: base/templates/pretixbase/cachedfiles/pending.html:23
msgid ""
"If this takes longer than a few minutes, please refresh this page or contact "
"us."
msgstr "បើចំណាយពេលលើសពីប៉ុន្មាននាទី សូមធ្វើបច្ចុប្បន្នភាពទំព័រនេះ ឬទាក់ទង។"

