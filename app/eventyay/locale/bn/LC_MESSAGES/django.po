#: base/models/product.py:677
msgid ""
"The maximum number per order can not be lower than the minimum number per "
"order."
msgstr "অর্ডারপ্রতি সর্বোচ্চ সংখ্যা অর্ডারপ্রতি সর্বনিম্ন সংখ্যার চেয়ে কম হতে পারে না।"

#: base/models/product.py:683
msgid "The product's category must belong to the same event as the product."
msgstr "পণ্যের বিভাগটি পণ্যের মতো একই ইভেন্টের অন্তর্ভুক্ত হতে হবে।"

#: base/models/product.py:688
msgid "The product's tax rule must belong to the same event as the product."
msgstr "পণ্যের কর বিধি অবশ্যই পণ্যের একই ইভেন্টের অন্তর্ভুক্ত হতে হবে।"

#: base/models/product.py:694
msgid "The product's availability cannot end before it starts."
msgstr "পণ্যের উপলভ্যতা শুরু হওয়ার আগে শেষ হতে পারে না।"

#: base/models/product.py:734
msgid "This is shown below the variation name in lists."
msgstr "তালিকায় ভ্যারিয়েশন নামের নিচে এটি প্রদর্শিত হয়।"

#: base/models/product.py:738 base/models/product.py:966
#: base/models/product.py:1198
msgid "Position"
msgstr "অবস্থান"

#: base/models/product.py:761 base/models/vouchers.py:176
#: base/models/waitinglist.py:72 base/orderimport.py:217
msgid "Product variation"
msgstr "পণ্য ভ্যারিয়েশন"

#: base/models/product.py:762
#: control/templates/pretixcontrol/item/create.html:63
msgid "Product variations"
msgstr "পণ্য ভ্যারিয়েশনসমূহ"

#: base/models/product.py:952
msgid "Minimum number"
msgstr "ন্যূনতম সংখ্যা"

#: base/models/product.py:953
msgid "Maximum number"
msgstr "সর্বাধিক সংখ্যা"

#: base/models/product.py:956
msgid "Add-Ons are included in the price"
msgstr "অ্যাড-অনগুলো মূল্যের মধ্যে অন্তর্ভুক্ত"

#: base/models/product.py:958
msgid ""
"If selected, adding add-ons to this ticket is free, even if the add-ons "
"would normally cost money individually."
msgstr ""
"নির্বাচিত হলে, এই টিকিটে অ্যাড-অন যোগ করা বিনামূল্যে, এমনকি অ্যাড-অনগুলো সাধারণত "
"আলাদাভাবে কিনলে খরচ হলেও।"

#: base/models/product.py:964
msgid "Allow the same product to be selected multiple times"
msgstr "একই পণ্য একাধিকবার নির্বাচন করার অনুমতি দিন"

#: base/models/product.py:980
msgid "The add-on's category must belong to the same event as the product."
msgstr "অ্যাড-অনের বিভাগটি অবশ্যই পণ্যের একই ইভেন্টের অন্তর্ভুক্ত হতে হবে।"

#: base/models/product.py:985
msgid "The product already has an add-on of this category."
msgstr "পণ্যে ইতিমধ্যেই এই বিভাগের একটি অ্যাড-অন রয়েছে।"

#: base/models/product.py:990
msgid "The minimum count needs to be equal to or greater than zero."
msgstr "ন্যূনতম সংখ্যা শূন্যের সমান বা শূন্যের বেশি হতে হবে।"

#: base/models/product.py:995
msgid "The maximum count needs to be equal to or greater than zero."
msgstr "সর্বাধিক সংখ্যা শূন্যের সমান বা শূন্যের বেশি হতে হবে।"

#: base/models/product.py:1000
msgid "The maximum count needs to be greater than the minimum count."
msgstr "সর্বাধিক সংখ্যা ন্যূনতম সংখ্যার চেয়ে বেশি হতে হবে।"

#: base/models/product.py:1024 control/forms/product.py:850
#: control/templates/pretixcontrol/item/include_bundles.html:23
#: control/templates/pretixcontrol/item/include_bundles.html:50
msgid "Bundled product"
msgstr "বান্ডেল করা পণ্য"

#: base/models/product.py:1030
msgid "Bundled variation"
msgstr "বান্ডেল করা ভ্যারিয়েশন"

#: base/models/product.py:1035 base/models/product.py:1140
#: base/models/question.py:48
msgid "Number"
msgstr "সংখ্যা"

