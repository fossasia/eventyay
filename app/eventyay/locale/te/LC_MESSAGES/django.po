msgstr "భౌగోళిక సమన్వయాలు నవీకరించబడ్డాయి"

#: control/templates/pretixcontrol/event/fragment_geodata_autoupdate.html:7
msgid "Update map?"
msgstr "మ్యాప్‌ను నవీకరించాలా?"

#: control/templates/pretixcontrol/event/fragment_info_box.html:5
msgid "Event organizer"
msgstr "ఈవెంట్ నిర్వాహకుడు"

#: control/templates/pretixcontrol/event/fragment_info_box.html:10
msgid "This event is organized by"
msgstr "ఈ ఈవెంట్‌ను నిర్వహించింది"

#: control/templates/pretixcontrol/event/fragment_info_box.html:13
