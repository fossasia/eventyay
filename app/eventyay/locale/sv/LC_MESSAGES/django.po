#: plugins/banktransfer/templates/pretixplugins/banktransfer/control.html:8
msgid "Account"
msgstr "Konto"

#: cfp/flow.py:501
msgid "That’s it about your proposal! We now just need a way to contact you."
msgstr ""
"Allt klart kring ditt förslag! Vi behöver nu bara ett sätt att kontakta dig."

#: cfp/flow.py:506
msgid ""
"To create your proposal, you need an account on this page. This not only "
"gives us a way to contact you, it also gives you the possibility to edit "
"your proposal or to view its current state."
msgstr ""
"För att skapa ett förslag behöver du ett konto på denna sida. Förutom att "
"det ger oss ett sätt att kontakta dig, ger det dig ett sätt att editera ditt "
"förslag och se dess status."

#: cfp/flow.py:549
#: eventyay_common/templates/eventyay_common/sessions/sessions.html:36
msgid "Profile"
msgstr "Profil"

#: cfp/flow.py:553
msgid "Tell us something about yourself!"
msgstr "Berätta lite om dig själv!"

#: cfp/flow.py:558
msgid ""
"This information will be publicly displayed next to your session - you can "
"always edit for as long as proposals are still open."
msgstr ""
"Denna information kommer att visas publikt i anslutning till din session - "
"du kan editera den så länge förslagen är öppna."

#: cfp/phrases.py:7
msgid "Go to CfP"
msgstr "Gå till KfM"

#: cfp/phrases.py:10
msgid ""
"If we know a user by this email address (who has not requested a password "
"reset in the last 24 hours), we will send you an email containing further "
"instructions. If you don’t see the email within the next minutes, check your "
"spam inbox!"
msgstr ""
"Om vi har en användare med denna epostadress (som inte har begärt en "
"lösenordsåtersällning de senaste 24 timmarna), kommer vi skicka ett mail med "
"vidare instruktioner. Om du inte ser något i din inkorg inom de närmsta "
"minutera, vänligen kolla i din skräppost!"

#: cfp/phrases.py:14
msgid ""
"This link was not valid. Make sure you copied the complete URL from the "
"email and that the email is no more than 24 hours old."
msgstr ""
"Denna länk är inte tillgänglig. Säkerställ att du kopierade hela sökvägen "
"från mailet och att mailet inte är mer än 24 timmar gammalt."

#: cfp/phrases.py:17
msgid "Awesome! You can now log in using your new password."
msgstr "Fantastiskt! Du kan nu logga in med ditt nya lösenord."

#: cfp/phrases.py:19
msgid "Your proposal has been withdrawn."
msgstr "Ditt förslag har blivit tillbakadraget."

#: cfp/phrases.py:21
msgid ""
"Your proposal can’t be withdrawn at this time – please contact us if you "
"need to withdraw your proposal!"
msgstr ""
"Det går inte att dra tillbaka ditt förslag just nu - vänligen kontakta oss "
"om du behöver dra tillbaka det!"

#: cfp/phrases.py:23
msgid "Your session has been confirmed – we’re looking forward to seeing you!"
msgstr "Din session har bekräftats - vi ser fram emot att träffa dig!"

#: cfp/phrases.py:24
msgid ""
"This proposal has already been confirmed – we’re looking forward to seeing "
"you!"
msgstr "Detta förslag har redan bekräftats - vi ser fram emot att träffa dig!"

#: cfp/phrases.py:26
msgid ""
"This proposal cannot be confirmed at this time – please contact us if you "
"think this is an error."
msgstr ""
"Detta förslag kan inte bekräftas just nu - kontakta oss om du tror att det "
"kan vara fel."

#: cfp/phrases.py:28
msgid "This proposal cannot be edited anymore."
msgstr "Detta förslag går inte att redigera längre."

#: cfp/phrases.py:30 cfp/phrases.py:53
msgid "Speaker email"
msgstr "Föreläsarens epost"

#: cfp/phrases.py:31 cfp/phrases.py:54
#, python-brace-format
msgid "{speaker} invites you to join their session!"
msgstr "{speaker} bjuder in dig till att delta på sin session!"

#: cfp/phrases.py:33 cfp/phrases.py:56
#, python-brace-format
msgid ""
"Hi!\n"
"\n"
"I’d like to invite you to be a speaker in the session\n"
"\n"
"  “{title}”\n"
"\n"
"at {event}. Please follow this link to join:\n"
"\n"
"  {url}\n"
"\n"
"I’m looking forward to it!\n"
"{speaker}"
msgstr ""
"Hej.\n"
"\n"
"Jag erbjuder dig härmed att föreläsa på denna session\n"
"\n"
"{title}\n"
"\n"
"på {event}. Följ denna länk för att acceptera:\n"
"\n"
"{url}\n"
"\n"
"Jag ser fram emot att hålla detta med dig.\n"
"{speaker}"

#: cfp/phrases.py:46
msgid "Please provide a valid email address."
msgstr "Vänligen fyll i en giltig epostadress."

#: cfp/phrases.py:47
msgid "The invitation was sent!"
msgstr "Inbjudan har skickats!"

#: cfp/phrases.py:48
msgid "You are now part of this proposal! Please fill in your profile below."
msgstr "Du är nu en del av detta förslag! Vänligen fyll i din profil nedan."

#: cfp/phrases.py:51
msgid ""
"We are experiencing difficulties when sending mails, but your session was "
"submitted successfully!"
msgstr "Vi har problem med att skicka epost, men din session har skickats in!"

#: cfp/phrases.py:69 orga/views/cfp.py:343
msgid "Custom fields"
msgstr "Anpassade fält"

#: cfp/templates/cfp/event/cfp.html:31
#, python-format
msgid ""
"You can enter proposals until %(deadline)s (%(timezone)s), %(until_string)s "
"from now."
msgstr ""
"Du kan skicka in förslag fram till %(deadline)s%(timezone)s, stänger om "
"%(until_string)s."

#: cfp/templates/cfp/event/cfp.html:35
#, python-format
msgid "This Call for Papers closed on %(deadline)s (%(timezone)s)."
msgstr "Denna Kallese för Medverkan stängde %(deadline)s (%(timezone)s)."

#: cfp/templates/cfp/event/cfp.html:60
msgid "View or edit speaker profile"
msgstr "Visa eller redigera talarprofil"

#: cfp/templates/cfp/event/cfp.html:67
msgid "Submit a proposal"
msgstr "Skicka in ett förslag"

#: cfp/templates/cfp/event/cfp.html:69 cfp/views/wizard.py:46
msgid "Proposals are closed"
msgstr "Förslagslådan är stängd"

#: cfp/templates/cfp/event/index.html:36
msgid "Go To Organiser Area"
msgstr "Gå till arrangörsområdet"

#: cfp/templates/cfp/event/invitation.html:7
#: cfp/templates/cfp/event/invitation.html:10
msgid "Accept invitation?"
msgstr "Acceptera inbjudan?"

#: cfp/templates/cfp/event/invitation.html:14
msgid ""
"Unfortunately, you cannot accept this invitation at the moment. This may be "
"because the invitation has expired, or because the proposal cannot be edited "
"any more."
msgstr ""
"Tyvärr kan du inte acceptera denna inbjudan just nu. Det kan vara för att "
"inbjudan har gått ut eller för att förslaget inte kan redigeras längre."

#: cfp/templates/cfp/event/invitation.html:21
msgid "Please contact the conference organizers for more information."
msgstr "Vänligen kontakta organisatörerna för mer information."

#: cfp/templates/cfp/event/invitation.html:27
#, python-format
msgid ""
"You, %(name)s, have been invited to be a speaker for the session “%(talk)s”. "
"Do you accept the invitation?"
msgstr ""
"Du, %(name)s, har blivit inbjuden till att bli föreläsare för sessionen "
"%(talk)s. Accepterar du inbjudan?"

#: cfp/templates/cfp/event/invitation.html:35
msgid "Abstract:"
msgstr "Samanfattning:"

#: cfp/templates/cfp/event/invitation.html:45
msgid "Accept invitation"
msgstr "Acceptera inbjudan"

