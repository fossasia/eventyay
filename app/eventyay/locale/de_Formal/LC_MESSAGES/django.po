msgstr "Zusätzliche Gebühr"

#: base/payment.py:315
msgid "Absolute value"
msgstr "Absoluter Wert"

#: base/payment.py:326
msgid "Percentage of the order total."
msgstr "Prozentsatz der Bestellsumme."

