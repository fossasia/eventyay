#: base/configurations/default_setting.py:2466
msgid "Link back to organizer overview on all event pages"
msgstr ""
"Link zur Übersichtsseite des Veranstalters auf allen Veranstaltungsseiten"

#: base/configurations/default_setting.py:2475
