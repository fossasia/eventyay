msgstr ""
"Lippukaupan on oltava offline-tilassa, jotta tätä ominaisuutta voi käyttää."

#: base/shredder.py:142
msgid "Phone numbers"
msgstr "Puhelinnumerot"

#: base/shredder.py:144
msgid "This will remove all phone numbers from orders."
msgstr "Tämä poistaa kaikki puhelinnumerot tilauksista."

#: base/shredder.py:173
msgid "E-mails"
msgstr "Sähköpostit"

#: base/shredder.py:176
msgid ""
"This will remove all e-mail addresses from orders and attendees, as well as "
"logged email contents."
msgstr ""
"Tämä poistaa kaikki sähköpostiosoitteet tilauksista ja osallistujilta sekä "
"kirjatun sähköpostisisällön."

#: base/shredder.py:233
msgid ""
"This will remove all names, email addresses, and phone numbers from the "
"waiting list."
msgstr ""
"Tämä poistaa kaikki nimet, sähköpostiosoitteet ja puhelinnumerot "
"jonotuslistalta."

#: base/shredder.py:268
msgid "Attendee info"
msgstr "Osallistujatiedot"

#: base/shredder.py:271
msgid ""
"This will remove all attendee names and postal addresses from order "
"positions, as well as logged changes to them."
msgstr ""
"Tämä poistaa kaikki osallistujien nimet ja postiosoitteet tilausriveiltä "
"sekä niihin kohdistuneet kirjatut muutokset."

#: base/shredder.py:338
msgid "Invoice addresses"
msgstr "Laskutusosoitteet"

#: base/shredder.py:341
msgid ""
"This will remove all invoice addresses from orders, as well as logged "
"changes to them."
msgstr ""
"Tämä poistaa kaikki laskutusosoitteet tilauksista sekä niihin kohdistuneet "
"kirjatut muutokset."

#: base/shredder.py:372
msgid "Question answers"
msgstr "Kysymysvastaukset"

#: base/shredder.py:374
msgid ""
"This will remove all answers to questions, as well as logged changes to them."
msgstr ""
"Tämä poistaa kaikki kysymysten vastaukset sekä niihin kohdistuneet kirjatut "
"muutokset."

#: base/shredder.py:411
msgid ""
"This will remove all invoice PDFs, as well as any of their text content that "
"might contain personal data from the database. Invoice numbers and totals "
"will be conserved."
msgstr ""
"Tämä poistaa kaikki lasku-PDF:t sekä niiden mahdollisen tekstisisällön, joka "
"voi sisältää henkilötietoja, tietokannasta. Laskunumerot ja summat "
"säilytetään."

#: base/shredder.py:439
msgid "Cached ticket files"
msgstr "Välimuistissa olevat lippupaketit"

#: base/shredder.py:441
msgid "This will remove all cached ticket files. No download will be offered."
msgstr ""
"Tämä poistaa kaikki välimuistissa olevat lippupaketit. Latausta ei tarjota."

#: base/shredder.py:457
msgid ""
"This will remove payment-related information. Depending on the payment "
"method, all data will be removed or personal data only. No download will be "
"offered."
msgstr ""
"Tämä poistaa maksuihin liittyvät tiedot. Maksutavasta riippuen joko kaikki "
"tiedot tai vain henkilötiedot poistetaan. Latausta ei tarjota."

