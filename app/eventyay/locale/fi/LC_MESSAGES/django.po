msgstr "Tämä kutsu sulkeutui %(deadline)s (%(timezone)s)."

#: cfp/templates/cfp/event/cfp.html:60
msgid "View or edit speaker profile"
msgstr "Näytä tai muokkaa puhujaprofiilia"

#: cfp/templates/cfp/event/cfp.html:67
msgid "Submit a proposal"
msgstr "Lähetä ehdotus"

#: cfp/templates/cfp/event/cfp.html:69 cfp/views/wizard.py:46
