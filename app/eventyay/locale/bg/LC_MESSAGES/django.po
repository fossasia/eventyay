#: orga/templates/orga/base.html:450 orga/templates/orga/organizer/list.html:8
msgid "Teams"
msgstr "Екипи"

#: base/models/organizer.py:428
msgid "Reviewer Manager — can edit and manage submissions"
msgstr "Мениджър на рецензенти — може да редактира и управлява предложения"

#: base/models/organizer.py:430
msgid ""
"Can edit submission details, change proposal states (accept/reject/"
"waitlist), manage submission metadata, and oversee the review workflow. This "
"provides full management permissions beyond standard reviewing."
msgstr ""
"Може да редактира подробности по предложенията, да променя състоянията на "
"предложенията (приемане/отхвърляне/в списък на чакащите), да управлява "
"метаданните на предложенията и да наблюдава работния процес по рецензиране. "
"Това предоставя пълни права за управление отвъд стандартното рецензиране."

#: base/models/organizer.py:437
msgid "Reviewer — can only review submissions"
msgstr "Рецензент — може само да преглежда кандидатури"

#: base/models/organizer.py:439
msgid ""
"Can review and provide feedback on submissions but cannot edit details or "
"change submission states."
msgstr ""
"Може да рецензира и да предоставя обратна връзка по предложенията, но не "
"може да редактира подробности или да променя състоянията на предложенията."

#: base/models/organizer.py:443
msgid "Always hide speaker names"
msgstr "Винаги да се скриват имената на лекторите"

#: base/models/organizer.py:445
msgid ""
"Normally, anonymisation is configured in the event review settings. This "
"setting will <strong>override the event settings</strong> and always hide "
"speaker names for this team."
msgstr ""
"Обикновено анонимизирането се конфигурира в настройките за преглед на "
"събития. Тази настройка <strong>ще замени настройките на събитието</strong> "
"и винаги ще скрие имената на лекторите за този екип."

#: base/models/organizer.py:454
msgid "Video: Can create stages"
msgstr "Видео: Може да създава сцени"

#: base/models/organizer.py:455
msgid "Allows creating livestream stages inside Eventyay Video."
msgstr ""
"Позволява създаване на сцени за livestream в рамките на Eventyay Video."

#: base/models/organizer.py:459
msgid "Video: Can create channels"
msgstr "Видео: Може да създава канали"

#: base/models/organizer.py:460
msgid "Allows creating chat/video channels inside Eventyay Video."
msgstr "Позволява създаване на чат/видео канали в рамките на Eventyay Video."

#: base/models/organizer.py:464
msgid "Video: Can send direct messages"
msgstr "Видео: Може да изпраща директни съобщения"

#: base/models/organizer.py:465
msgid "Grants permission to open new direct message conversations."
msgstr ""
"Предоставя разрешение за отваряне на нови разговори с директни съобщения."

#: base/models/organizer.py:469
msgid "Video: Can create announcements"
msgstr "Видео: Може да създава съобщения"

#: base/models/organizer.py:470
msgid "Allows posting announcements in the Eventyay Video interface."
msgstr "Позволява публикуване на съобщения в интерфейса на Eventyay Video."

#: base/models/organizer.py:474
msgid "Video: Can view users"
msgstr "Видео: Може да преглежда потребители"

#: base/models/organizer.py:475
msgid "Allows access to the user directory in Eventyay Video."
msgstr "Позволява достъп до потребителската директория в Eventyay Video."

#: base/models/organizer.py:479
msgid "Video: Can message, ban, and silence users"
msgstr ""
"Видео: Може да изпраща съобщения, да забранява и да заглушава потребители"

#: base/models/organizer.py:480
msgid "Allows moderating users (ban, silence, reactivate) in Eventyay Video."
msgstr ""
"Позволява модериране на потребители (забрана, заглушаване, повторно "
"активиране) в Eventyay Video."

#: base/models/organizer.py:484
msgid "Video: Can create and edit rooms"
msgstr "Видео: Може да създава и редактира стаи"

#: base/models/organizer.py:485
msgid "Allows editing and deleting rooms inside Eventyay Video."
msgstr "Позволява редактиране и изтриване на стаи в Eventyay Video."

#: base/models/organizer.py:489
msgid "Video: Can create and edit kiosks"
msgstr "Видео: Може да създава и редактира киоски"

#: base/models/organizer.py:490
msgid "Allows managing kiosk displays inside Eventyay Video."
msgstr "Позволява управление на киоск дисплеи в Eventyay Video."

#: base/models/organizer.py:494
msgid "Video: Can edit event configuration"
msgstr "Видео: Може да редактира конфигурацията на събитието"

#: base/models/organizer.py:495
msgid "Allows editing the global Eventyay Video configuration."
msgstr "Позволява редактиране на глобалната конфигурация на Eventyay Video."

#: base/models/organizer.py:534
#, python-brace-format
msgid "Invite to team '{team}' for '{email}'"
msgstr "Покана за екип „{team}“ за „{email}“"

#: base/models/organizer.py:551
#, python-brace-format
msgid ""
"Hi!\n"
"You have been invited to the {name} event organizer team - Please click here "
"to accept:\n"
"\n"
"{invitation_link}\n"
"\n"
"See you there,\n"
"The {organizer} team"
msgstr ""
"Здравейте!\n"
"Поканени сте в екипа на организаторите на събитието {name} - Моля, кликнете "
"тук, за да приемете:\n"
"\n"
"{invitation_link}\n"
"\n"
"До скоро,\n"
"Екипът на {organizer}"

#: base/models/organizer.py:563
msgid "You have been invited to an organizer team"
msgstr "Поканени сте в екип на организаторите"

