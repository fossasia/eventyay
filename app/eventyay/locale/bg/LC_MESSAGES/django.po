msgid "Team"
msgstr "Екип"

#: base/models/organizer.py:421 eventyay_common/navigation.py:175
#: eventyay_common/templates/eventyay_common/organizers/edit.html:8
#: eventyay_common/templates/eventyay_common/organizers/edit.html:13
