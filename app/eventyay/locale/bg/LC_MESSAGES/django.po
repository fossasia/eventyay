msgstr "Извличане на географски координати …"

#: control/templates/pretixcontrol/event/fragment_geodata_autoupdate.html:6
msgid "Geo coordinates updated"
msgstr "Географските координати са актуализирани"

#: control/templates/pretixcontrol/event/fragment_geodata_autoupdate.html:7
msgid "Update map?"
msgstr "Актуализиране на картата?"

#: control/templates/pretixcontrol/event/fragment_info_box.html:5
msgid "Event organizer"
msgstr "Организатор на събитието"

#: control/templates/pretixcontrol/event/fragment_info_box.html:10
msgid "This event is organized by"
msgstr "Това събитие е организирано от"

#: control/templates/pretixcontrol/event/fragment_info_box.html:13
msgid "Teams of the organizer are"
msgstr "Екипите на организатора са"

