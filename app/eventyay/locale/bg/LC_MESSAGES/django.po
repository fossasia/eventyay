#: eventyay_common/templates/eventyay_common/events/create_foundation.html:94
msgid "Localization"
msgstr "Локализация"

#: control/forms/global_settings.py:399
msgid "Payment Gateways"
msgstr "Платежни шлюзове"

#: control/forms/global_settings.py:422
msgid "Ticket fee"
msgstr "Такса за билет"

#: control/forms/global_settings.py:428
msgid "Maps"
msgstr "Карти"

#: control/forms/global_settings.py:453
msgid ""
"During the update check, eventyay will report an anonymous, unique "
"installation ID, the current version of the system and your installed "
"plugins and the number of active and inactive events in your installation to "
"servers operated by the eventyay developers. We will only store anonymous "
"data, never any IP addresses and we will not know who you are or where to "
"find your instance. You can disable this behavior here at any time."
msgstr ""
"По време на проверката за обновления eventyay ще докладва анонимен, уникален "
"идентификатор на инсталацията, текущата версия на системата и инсталираните "
"от вас плъгини, както и броя на активните и неактивните събития във вашата "
"инсталация, към сървъри, управлявани от разработчиците на eventyay. Ще "
"съхраняваме само анонимни данни, никога IP адреси и няма да знаем кой сте "
"или къде да намерим вашия екземпляр. Можете да изключите това поведение тук "
"по всяко време."

#: control/forms/global_settings.py:462
msgid "E-mail notifications"
msgstr "Имейл известия"

#: control/forms/global_settings.py:464
msgid ""
"We will notify you at this address if we detect that a new update is "
"available. This address will not be transmitted to eventyay.com, the emails "
"will be sent by this server locally."
msgstr ""
"Ще ви уведомим на този адрес, ако засечем, че е налично ново обновление. "
"Този адрес няма да бъде предаван на eventyay.com; имейлите ще бъдат "
"изпращани локално от този сървър."

#: control/forms/global_settings.py:473
msgid "Enable telemetry"
msgstr "Активиране на телеметрия"

#: control/forms/global_settings.py:475
msgid ""
"Send anonymous usage statistics (bucketed counts, deployment info) to help "
"track version adoption and deployment patterns. No personal data is "
"collected. Data is sent approximately once per day."
msgstr ""
"Изпращайте анонимна статистика за употребата (групирани броеве, информация "
"за внедряването), за да помогнете за проследяване на приемането на версии и "
"модели на внедряване. Не се събират лични данни. Данните се изпращат "
"приблизително веднъж на ден."

#: control/forms/global_settings.py:482
msgid "Telemetry endpoint"
msgstr "Крайна точка за телеметрия"

#: control/forms/global_settings.py:483
msgid "The URL where telemetry data will be sent (Google Apps Script URL)."
msgstr ""
"URL адресът, към който ще бъдат изпращани телеметричните данни (URL адрес на "
"Google Apps Script)."

#: control/forms/global_settings.py:487
msgid "Telemetry API key"
msgstr "API ключ за телеметрия"

#: control/forms/global_settings.py:488
msgid "API key for authenticating with the telemetry receiver."
msgstr "API ключ за удостоверяване с получателя на телеметрия."

#: control/forms/global_settings.py:492
msgid "Maintainer contact"
msgstr "Контакт за поддръжка"

#: control/forms/global_settings.py:494
msgid ""
"Optional email address included in telemetry data to identify who maintains "
"this instance. Only visible to those with access to the telemetry data sheet."
msgstr ""
"Незадължителен имейл адрес, включен в телеметричните данни, за да се "
"идентифицира кой поддържа тази инстанция. Видим е само за тези, които имат "
"достъп до таблицата с телеметрични данни."

#: control/forms/global_settings.py:507
msgid "Redirect URL"
msgstr "URL за пренасочване"

#: control/forms/global_settings.py:548
msgid "The Stripe key cannot be empty."
msgstr "Ключът за Stripe не може да бъде празен."

#: control/forms/global_settings.py:552
#, python-format
msgid ""
"The provided key does not look valid. It should start with \"%(prefix)s\"."
msgstr ""
"Предоставеният ключ не изглежда валиден. Той трябва да започва с "
"\"%(prefix)s\"."

#: control/forms/global_settings.py:555
#, python-format
msgid ""
"The provided key does not look valid. It should start with one of: "
"%(prefixes)s"
msgstr ""
"Предоставеният ключ не изглежда валиден. Той трябва да започва с едно от: "
"%(prefixes)s"

