msgstr "Будь-яка країна"

#: control/forms/event.py:1358
msgid "European Union"
msgstr "Європейський Союз"

#: control/forms/event.py:1367
msgid "Any customer"
msgstr "Будь-який клієнт"

#: control/forms/event.py:1368
msgid "Individual"
msgstr "Фізична особа"

#: control/forms/event.py:1369
msgid "Business"
msgstr "Бізнес"

