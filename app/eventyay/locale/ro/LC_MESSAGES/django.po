msgstr ""
"Marcarea sesiunilor ca „recomandate” este o modalitate bună de a le afișa "
"înainte de publicarea primului program sau de a le evidenția odată ce "
"programul este vizibil."

#: orga/forms/event.py:78
msgid "Enable anonymous feedback"
msgstr "Activează feedback anonim"

#: orga/forms/event.py:79
