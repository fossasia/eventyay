#: event/forms.py:214
msgid "You cannot change the slug later on!"
msgstr "பின்னர் ஸ்லக்கை மாற்ற முடியாது!"

#: event/forms.py:224
msgid ""
"This short name is already taken, please choose another one (or ask the "
"owner of that event to add you to their team)."
msgstr ""
"இந்த குறும்பெயர் ஏற்கனவே பயன்படுத்தப்படுகிறது; வேறொன்றைத் தேர்வு செய்யவும் (அல்லது அந்த "
"நிகழ்வின் உரிமையாளரிடம் தங்களின் அணியில் சேர்க்குமாறு கேட்கவும்)."

#: event/forms.py:320
msgid ""
"You can copy settings from previous events here, such as mail settings, "
"session types, and email templates. Please check those settings once the "
"event has been created!"
msgstr ""
"முன்னைய நிகழ்வுகளிலிருந்து அமைப்புகளை இங்கே நகலெடுக்கலாம்; உதாரணமாக மின்னஞ்சல் "
"அமைப்புகள், அமர்வு வகைகள், மற்றும் மின்னஞ்சல் வார்ப்புருக்கள். நிகழ்வு உருவாக்கப்பட்ட பிறகு "
"அந்த அமைப்புகளைச் சரிபார்க்கவும்!"

#: event/stages.py:41
msgid "Preparation"
msgstr "தயார்ப்பு"

#: event/stages.py:45
msgid "Configure the event"
msgstr "நிகழ்வை அமை"

#: event/stages.py:46
msgid "Gather your team"
msgstr "அணியை ஒன்றுசேர்க்க"

#: event/stages.py:47
msgid "Write a CfP"
msgstr "CfP எழுது"

#: event/stages.py:49
msgid "Customize mail templates"
msgstr "மின்னஞ்சல் வார்ப்புருக்களை தனிப்பயனாக்கு"

#: event/stages.py:55
msgid "CfP is open"
msgstr "CfP திறந்துள்ளது"

#: event/stages.py:59
msgid "Monitor proposals"
msgstr "முன்மொழிவுகளை கண்காணி"

#: event/stages.py:61
msgid "Submit sessions for your speakers"
msgstr "பேச்சாளர்களுக்காக அமர்வுகளை சமர்ப்பி"

#: event/stages.py:64
msgid "Invite reviewers"
msgstr "மதிப்பாய்வாளர்களை அழை"

#: event/stages.py:72
msgid "Let reviewers do their work"
msgstr "மதிப்பாய்வாளர்கள் பணியைச் செய்ய விடு"

#: event/stages.py:74
msgid "Accept or reject proposals"
msgstr "முன்மொழிவுகளை ஏற்று அல்லது நிராகரி"

#: event/stages.py:77
msgid "Build your first schedule"
msgstr "முதல் அட்டவணையை உருவாக்கு"

#: event/stages.py:86
msgid "Release schedules as needed"
msgstr "தேவைக்கேற்ப அட்டவணைகளை வெளியிடு"

#: event/stages.py:90
msgid "Inform your speakers about the infrastructure"
msgstr "உள்கட்டமைப்பு குறித்து பேச்சாளர்களுக்கு அறிவி"

#: event/stages.py:100
msgid "Provide a point of contact for the speakers"
msgstr "பேச்சாளர்களுக்கான தொடர்பு நபரை வழங்கு"

#: event/stages.py:101
msgid "Enjoy the event!"
msgstr "நிகழ்வை அனுபவி!"

#: event/stages.py:105
msgid "Wrapup"
msgstr "முடிவுறுத்தல்"

#: event/stages.py:109
msgid "Monitor incoming feedback"
msgstr "வரும் கருத்துகளை கண்காணிக்கவும்"

#: event/stages.py:110
msgid "Embed session recordings if available"
msgstr "கிடைத்தால் அமர்வு பதிவுகளை உட்பொதிக்கவும்"

#: event/stages.py:111
msgid "Release next event date?"
msgstr "அடுத்த நிகழ்வு தேதியை வெளியிடவா?"

#: eventyay_common/forms/event.py:107
msgid "You need to configure the custom domain in the webserver beforehand."
msgstr "தனிப்பயன் டொமைனை முன்கூட்டியே வெப்சர்வரில் உள்ளமைக்க வேண்டும்."

#: eventyay_common/forms/filters.py:38
msgid "Search by session name"
msgstr "அமர்வு பெயரால் தேடவும்"

