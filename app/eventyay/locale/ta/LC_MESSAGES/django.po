msgstr "CfP இன்னும் முழு உரையுடன் இல்லை."

#: eventyay_common/views/event.py:595 orga/views/event.py:118
msgid ""
"You want submitters to choose the tracks for their proposals, but you do not "
"offer tracks for selection. Add at least one track!"
msgstr ""
"சமர்ப்பிப்பவர்கள் தங்களின் முன்மொழிவுகளுக்கான தடங்களைத் தேர்வு செய்ய வேண்டும், ஆனால் "
"தேர்விற்கு தடங்கள் எதுவும் வழங்கப்படவில்லை. குறைந்தபட்சம் ஒரு தடத்தைச் சேர்க்கவும்!"

#: eventyay_common/views/event.py:603 orga/views/event.py:126
msgid "You have configured only one session type so far."
msgstr "இதுவரை ஒரு அமர்வு வகை மட்டும் கட்டமைக்கப்பட்டுள்ளது."

#: eventyay_common/views/event.py:610
#: orga/templates/orga/cfp/talkquestion/list.html:127 orga/views/event.py:133
msgid "You have configured no custom fields yet."
msgstr "இதுவரை தனிப்பயன் புலங்கள் எதுவும் கட்டமைக்கப்படவில்லை."

#: eventyay_common/views/event.py:627
msgid "Please resolve the billing information before publishing the event."
msgstr "நிகழ்வை வெளியிடுவதற்கு முன் பில்லிங் தகவலைச் சரிசெய்யவும்."

#: eventyay_common/views/event.py:634
msgid "Your event is now online."
msgstr "நிகழ்வு இப்போது ஆன்லைனில் உள்ளது."

#: eventyay_common/views/event.py:642
msgid "Your event has been unpublished."
msgstr "நிகழ்வு வெளியீடு நீக்கப்பட்டது."

#: eventyay_common/views/event.py:741 orga/views/event.py:148
msgid "Publish the event before publishing talks."
msgstr "உரைகளை வெளியிடுவதற்கு முன் நிகழ்வை வெளியிடவும்."

#: eventyay_common/views/event.py:755 orga/views/event.py:162
msgid "Talk pages are now published."
msgstr "உரை பக்கங்கள் இப்போது வெளியிடப்பட்டுள்ளன."

#: eventyay_common/views/event.py:772 orga/views/event.py:178
msgid "Talk pages have been unpublished."
msgstr "உரை பக்கங்களின் வெளியீடு நீக்கப்பட்டது."

#: eventyay_common/views/event.py:777 orga/views/event.py:183
msgid "Talk pages must be published before enabling talk test mode."
msgstr "உரை சோதனை முறையை இயக்குவதற்கு முன் உரை பக்கங்கள் வெளியிடப்பட்டிருக்க வேண்டும்."

#: eventyay_common/views/event.py:797 orga/views/event.py:203
msgid "Talk pages are now in test mode!"
msgstr "உரை பக்கங்கள் இப்போது சோதனை முறையில் உள்ளன!"

#: eventyay_common/views/event.py:803 orga/views/event.py:209
msgid "Talk pages are now in production mode."
msgstr "உரை பக்கங்கள் இப்போது தயாரிப்பு முறையில் உள்ளன."

#: eventyay_common/views/event.py:844 orga/views/event.py:213
msgid "Private test mode cannot be enabled while talks are published."
msgstr "உரைகள் வெளியிடப்பட்டிருக்கும் போது தனிப்பட்ட சோதனை முறையை இயக்க முடியாது."

#: eventyay_common/views/event.py:870 orga/views/event.py:239
msgid "Private test mode is now enabled for talks."
msgstr "உரைகளுக்கு தனிப்பட்ட சோதனை முறை இப்போது இயக்கப்பட்டுள்ளது."

#: eventyay_common/views/event.py:870 orga/views/event.py:239
msgid "Private test mode is now disabled for talks."
msgstr "உரைகளுக்கு தனிப்பட்ட சோதனை முறை இப்போது முடக்கப்பட்டுள்ளது."

#: eventyay_common/views/organizer.py:72
msgid "New organizer is created."
msgstr "புதிய அமைப்பாளர் உருவாக்கப்பட்டார்."

#: eventyay_common/views/organizer.py:355 eventyay_common/views/team.py:312
msgid "The team has been created. You can now add members to the team."
msgstr "குழு உருவாக்கப்பட்டது. இப்போது குழுவில் உறுப்பினர்களைச் சேர்க்கலாம்."

#: eventyay_common/views/organizer.py:361
msgid ""
"Something went wrong, your changes could not be saved. Please see below for "
"details."
msgstr "ஏதோ தவறு ஏற்பட்டது, மாற்றங்களைச் சேமிக்க முடியவில்லை. விவரங்களுக்கு கீழே காணவும்."

#: eventyay_common/views/organizer.py:391 eventyay_common/views/team.py:409
#, python-format
msgid "Changes to the team '%(team_name)s' have been saved."
msgstr "'%(team_name)s' குழுவிற்கான மாற்றங்கள் சேமிக்கப்பட்டுள்ளன."

#: eventyay_common/views/organizer.py:397 eventyay_common/views/team.py:417
msgid "Something went wrong, your changes could not be saved."
msgstr "ஏதோ தவறு ஏற்பட்டது; மாற்றங்களைச் சேமிக்க முடியவில்லை."

#: eventyay_common/views/organizer.py:444 eventyay_common/views/team.py:129
msgid ""
"You cannot remove the last member from this team as no one would be left "
"with the permission to change teams."
msgstr ""
"இந்தக் குழுவிலிருந்து கடைசி உறுப்பினரை அகற்ற முடியாது; குழுக்களை மாற்றும் அனுமதி "
"கொண்டவர் எவரும் மீதமிருக்கமாட்டார்."

#: eventyay_common/views/organizer.py:456 eventyay_common/views/team.py:141
msgid "The member has been removed from the team."
msgstr "உறுப்பினர் குழுவிலிருந்து அகற்றப்பட்டார்."

#: eventyay_common/views/organizer.py:464
#: eventyay_common/views/organizer.py:481 eventyay_common/views/team.py:148
#: eventyay_common/views/team.py:164
msgid "Invalid invite selected."
msgstr "தவறான அழைப்பு தேர்ந்தெடுக்கப்பட்டது."

#: eventyay_common/views/organizer.py:473 eventyay_common/views/team.py:157
msgid "The invite has been revoked."
msgstr "அழைப்பு ரத்து செய்யப்பட்டது."

#: eventyay_common/views/organizer.py:490 eventyay_common/views/team.py:173
msgid "The invite has been resent."
msgstr "அழைப்பு மீண்டும் அனுப்பப்பட்டது."

#: eventyay_common/views/organizer.py:530 eventyay_common/views/team.py:253
msgid "The new member has been added to the team."
msgstr "புதிய உறுப்பினர் குழுவில் சேர்க்கப்பட்டார்."

#: eventyay_common/views/organizer.py:545 eventyay_common/views/team.py:206
msgid "Users need to have a eventyay account before they can be invited."
msgstr "அழைப்பதற்கு முன் பயனர்களுக்கு eventyay கணக்கு இருக்க வேண்டும்."

#: eventyay_common/views/organizer.py:556 eventyay_common/views/team.py:217
msgid "The new member has been invited to the team."
msgstr "புதிய உறுப்பினர் குழுவிற்கு அழைக்கப்பட்டார்."

#: eventyay_common/views/organizer.py:587 eventyay_common/views/team.py:180
msgid "Invalid token selected."
msgstr "தவறான டோக்கன் தேர்ந்தெடுக்கப்பட்டது."

#: eventyay_common/views/organizer.py:597 eventyay_common/views/team.py:190
msgid "The token has been revoked."
msgstr "டோக்கன் ரத்து செய்யப்பட்டது."

#: eventyay_common/views/organizer.py:611 eventyay_common/views/team.py:266
#, python-brace-format
msgid ""
"A new API token has been created with the following secret: {}\n"
"Please copy this secret to a safe place. You will not be able to view it "
