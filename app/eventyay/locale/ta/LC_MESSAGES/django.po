msgstr "பிழைகளுக்கான உச்சரிப்பு நிறம்"

#: base/configurations/default_setting.py:2058
msgid "We strongly suggest to use a shade of red."
msgstr "சிவப்பு நிறத்தின் ஒரு தொனியைப் பயன்படுத்த பரிந்துரைக்கப்படுகிறது."

#: base/configurations/default_setting.py:2082
msgid "Page background color"
msgstr "பக்கப் பின்னணி நிறம்"

#: base/configurations/default_setting.py:2106
