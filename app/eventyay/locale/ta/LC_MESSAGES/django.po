#: base/models/vouchers.py:399
#, python-brace-format
msgid "The specified seat ID \"{id}\" does not exist for this event."
msgstr "குறிப்பிட்ட இருக்கை ஐடி \"{id}\" இந்த நிகழ்வுக்கு இல்லை."

#: base/models/vouchers.py:404
#, python-brace-format
msgid ""
"The seat \"{id}\" is currently unavailable (blocked, already sold or a "
