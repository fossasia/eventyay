# TAG gives the docker image tag:
# - main for images build from the main branch
# - dev for images build from the dev branch
TAG=dev

# EVY_ variables are loaded into the django configuration
EVY_DEBUG=1
EVY_RUNNING_ENVIRONMENT=development
EVY_SITE_URL=http://localhost:8000
EVY_TALK_HOSTNAME=http://localhost:8000
EVY_SECRET_KEY=dev-secret-key-for-local-development-only
EVY_POSTGRES_DB=eventyay_dev
EVY_POSTGRES_USER=eventyay_dev_user
EVY_POSTGRES_PASSWORD=eventyay_dev_pass
EVY_POSTGRES_HOST=eventyay-next-db
EVY_POSTGRES_PORT=5432
EVY_ALLOWED_HOSTS='[ "localhost", "127.0.0.1", "*" ]'
EVY_REDIS_URL='redis://eventyay-next-redis/0'

# Email settings

# --- LOCAL DEVELOPMENT (Console) ---
# Emails are printed directly to the terminal stdout/stderr logs by default please comment this out when using sendgrid/gmail.
EVY_EMAIL_BACKEND='django.core.mail.backends.console.EmailBackend'

# --- REAL SMTP ALTERNATIVE (SendGrid / Gmail) ---
# To use a real SMTP service, change EVY_EMAIL_BACKEND and configure one of the options below.
#
# Option A: SendGrid
# 1. Sign up/log in to SendGrid and create an API Key with "Mail Send" permissions.
# 2. Verify your Sender Identity in SendGrid.
# 3. Configure the settings below:
# EVY_EMAIL_BACKEND='django.core.mail.backends.smtp.EmailBackend'
# EVY_EMAIL_HOST='smtp.sendgrid.net'
# EVY_EMAIL_PORT=587
# EVY_DEFAULT_FROM_EMAIL='your-verified-sender@yourdomain.com'
# EVY_EMAIL_HOST_USER='apikey'                            # Literal string 'apikey'
# EVY_EMAIL_HOST_PASSWORD='SG.your_sendgrid_api_key_here' # SendGrid API key
# EVY_EMAIL_USE_TLS=1
# EVY_EMAIL_USE_SSL=0
#
# Option B: Gmail SMTP
# 1. Enable 2-Step Verification on your Google Account.
# 2. Create an App Password (Google Account Security -> App Passwords).
# 3. Configure the settings below:
# EVY_EMAIL_BACKEND='django.core.mail.backends.smtp.EmailBackend'
# EVY_EMAIL_HOST='smtp.gmail.com'
# EVY_EMAIL_PORT=587
# EVY_DEFAULT_FROM_EMAIL='your-gmail-address@gmail.com'
# EVY_EMAIL_HOST_USER='your-gmail-address@gmail.com'
# EVY_EMAIL_HOST_PASSWORD='your_16_character_app_password' # App password (no spaces)
# EVY_EMAIL_USE_TLS=1
# EVY_EMAIL_USE_SSL=0

# --- FRONTEND LIVE DEVELOPMENT ---
# Set to 1 to auto-watch and re-compile Vite/npm apps on-the-fly when files change.
EVY_NPM_DEV=1

# database - postgres container setup
POSTGRES_HOST=eventyay-next-db
POSTGRES_PORT=5432
DATABASE=postgres
POSTGRES_DB=eventyay_dev
POSTGRES_USER=eventyay_dev_user
POSTGRES_PASSWORD=eventyay_dev_pass

# watchtower container setup (not used in development)
# WATCHTOWER_NOTIFICATION_URL=
# WATCHTOWER_NOTIFICATIONS_HOSTNAME=
